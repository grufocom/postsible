#!/bin/bash
# {{ ansible_managed }}
# Generate a self-signed certificate in the Let's Encrypt path layout.
# Usage: postsible-generate-selfsigned <hostname>

set -euo pipefail

HOSTNAME="${1:?Usage: $0 <hostname>}"
CERT_DIR="/etc/letsencrypt/live/${HOSTNAME}"
FULLCHAIN="${CERT_DIR}/fullchain.pem"
PRIVKEY="${CERT_DIR}/privkey.pem"
CHAIN="${CERT_DIR}/chain.pem"

mkdir -p "${CERT_DIR}"

if [ -f "${FULLCHAIN}" ] && [ -f "${PRIVKEY}" ]; then
    echo "✓ Certificate for ${HOSTNAME} already exists – skipping generation."
    exit 0
fi

echo "Generating self-signed certificate for ${HOSTNAME} ..."

openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
    -keyout "${PRIVKEY}" \
    -out    "${FULLCHAIN}" \
    -subj   "/CN=${HOSTNAME}/O=Postsible Self-Signed/C=AT" \
    -addext "subjectAltName=DNS:${HOSTNAME}"

# chain.pem = same as fullchain for self-signed (no intermediate)
ln -sf "${FULLCHAIN}" "${CHAIN}"

chown root:ssl-cert "${PRIVKEY}" "${FULLCHAIN}"
chmod 640 "${PRIVKEY}" "${FULLCHAIN}"
chmod 644 "${CHAIN}"

echo "✓ Self-signed certificate created: ${CERT_DIR}/"
openssl x509 -in "${FULLCHAIN}" -noout -subject -dates
