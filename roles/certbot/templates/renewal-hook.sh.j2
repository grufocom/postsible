#!/bin/bash
# {{ ansible_managed }}
# Certbot post-renewal hook – reloads services after certificate renewal

set -euo pipefail

{% for svc in certbot_reload_services %}
systemctl reload {{ svc }} 2>/dev/null || systemctl restart {{ svc }} 2>/dev/null || true
echo "✓ Reloaded: {{ svc }}"
{% endfor %}
