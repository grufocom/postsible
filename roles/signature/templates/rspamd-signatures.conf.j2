# {{ ansible_managed }}
# Postsible Signature Module – rspamd configuration
# The actual logic lives in signatures.lua (same local.d/ directory)

# Load our custom Lua module
lua = "${CONFDIR}/local.d/signatures.lua";

# The symbol is registered as a postfilter in the Lua file.
# No score needed – this is a content-modification module only.
POSTSIBLE_SIGNATURE {
    weight = 0;
    description = "Append per-user/per-domain email signature";
}
