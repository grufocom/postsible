#!/bin/bash
# {{ ansible_managed }}
# altermime-filter – Postfix content_filter for per-user email signatures
SIG_BASE="{{ signature_base_dir }}"
{% raw %}
# Called by Postfix as:
#   altermime-filter -f <sender> -- <recipients...>

set -euo pipefail

SENDMAIL="/usr/sbin/sendmail"
ALTERMIME="/usr/bin/altermime"
TMPDIR="/tmp"
LOGFILE="/var/log/altermime.log"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') altermime-filter: $*" >> "$LOGFILE"
}

# Parse arguments
SENDER=""
RECIPIENTS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f) SENDER="$2"; shift 2 ;;
        --) shift; RECIPIENTS=("$@"); break ;;
        *)  shift ;;
    esac
done

if [[ -z "$SENDER" || ${#RECIPIENTS[@]} -eq 0 ]]; then
    log "ERROR: missing sender or recipients"
    cat | "$SENDMAIL" -i "${RECIPIENTS[@]}"
    exit 0
fi

SENDER_LOWER="${SENDER,,}"

# Find signature
SIG_HTML=""
SIG_TXT=""

# 1. User-specific
USER_DIR="$SIG_BASE/users/$SENDER_LOWER"
if [[ -f "$USER_DIR/signature.html" ]]; then
    SIG_HTML="$USER_DIR/signature.html"
fi
if [[ -f "$USER_DIR/signature.txt" ]]; then
    SIG_TXT="$USER_DIR/signature.txt"
fi

# 2. Domain fallback
if [[ -z "$SIG_HTML" && -z "$SIG_TXT" ]]; then
    DOMAIN="${SENDER_LOWER#*@}"
    DOMAIN_DIR="$SIG_BASE/domains/$DOMAIN"
    if [[ -f "$DOMAIN_DIR/signature.html" ]]; then
        SIG_HTML="$DOMAIN_DIR/signature.html"
    fi
    if [[ -f "$DOMAIN_DIR/signature.txt" ]]; then
        SIG_TXT="$DOMAIN_DIR/signature.txt"
    fi
fi

# No signature found – pass through unchanged
if [[ -z "$SIG_HTML" && -z "$SIG_TXT" ]]; then
    log "no signature for <$SENDER_LOWER>, passing through"
    cat | "$SENDMAIL" -i "${RECIPIENTS[@]}"
    exit 0
fi

# Write mail to temp file
TMPFILE=$(mktemp "$TMPDIR/altermime-XXXXXX.eml")
trap 'rm -f "$TMPFILE"' EXIT

cat > "$TMPFILE"

# Run altermime
ALTERMIME_ARGS=("--input=$TMPFILE")

if [[ -n "$SIG_TXT" ]]; then
    ALTERMIME_ARGS+=("--disclaimer=$SIG_TXT")
fi
if [[ -n "$SIG_HTML" ]]; then
    ALTERMIME_ARGS+=("--disclaimer-html=$SIG_HTML")
fi
if [[ -z "$SIG_HTML" && -n "$SIG_TXT" ]]; then
    ALTERMIME_ARGS+=("--disclaimer-html=$SIG_TXT")
fi
ALTERMIME_ARGS+=("--force-for-bad-html")

if ! "$ALTERMIME" "${ALTERMIME_ARGS[@]}"; then
    log "ERROR: altermime failed for <$SENDER_LOWER>, passing through original"
    "$SENDMAIL" -i "${RECIPIENTS[@]}" < "$TMPFILE"
    exit 0
fi

log "signature appended for <$SENDER_LOWER>"

# Reinject into Postfix
"$SENDMAIL" -i "${RECIPIENTS[@]}" < "$TMPFILE"
{% endraw %}
