-- {{ ansible_managed }}
-- Postsible Signature Module for rspamd
-- Appends per-user or per-domain signatures to outbound mail
--
-- Lookup order:
--   1. /etc/rspamd/signatures/users/<from@domain>/  (user signature)
--   2. /etc/rspamd/signatures/domains/<domain>/     (domain fallback)
--   3. No signature – mail passes unmodified
--
-- Only processes mail leaving via the outbound smtp transport
-- (authenticated senders / relay).  Inbound mail is never modified.

local rspamd_logger  = require "rspamd_logger"
local rspamd_util    = require "rspamd_util"
local rspamd_mime    = require "rspamd_mime_types"

local BASE_DIR = "{{ signature_base_dir }}"

-- ── helpers ──────────────────────────────────────────────────────────────────

local function read_file(path)
    local fh, err = io.open(path, "rb")
    if not fh then return nil, err end
    local content = fh:read("*a")
    fh:close()
    return content
end

local function file_exists(path)
    local fh = io.open(path, "r")
    if fh then fh:close(); return true end
    return false
end

-- Returns the signature directory for a given email, or nil
local function find_sig_dir(from_email)
    -- 1. user-specific
    local user_dir = BASE_DIR .. "/users/" .. from_email
    if file_exists(user_dir .. "/signature.html") or
       file_exists(user_dir .. "/signature.txt") then
        return user_dir
    end

    -- 2. domain fallback
    local domain = from_email:match("@(.+)$")
    if domain then
        local domain_dir = BASE_DIR .. "/domains/" .. domain
        if file_exists(domain_dir .. "/signature.html") or
           file_exists(domain_dir .. "/signature.txt") then
            return domain_dir
        end
    end

    return nil
end

-- Encode binary string to base64
local function b64(data)
    return rspamd_util.encode_base64(data, 0)
end

-- Generate a stable Content-ID from the signature directory path
local function make_cid(sig_dir)
    local host = "{{ common_hostname }}"
    -- simple deterministic id based on dir hash
    local h = 0
    for i = 1, #sig_dir do h = (h * 31 + sig_dir:byte(i)) % 0xFFFFFFFF end
    return string.format("sig-logo-%x@%s", h, host)
end

-- ── core callback ─────────────────────────────────────────────────────────────

local function signature_cb(task)

    -- Only process authenticated (outbound) mail
    local user = task:get_user()
    if not user then return end

    -- Get envelope From
    local from = task:get_from('smtp')
    if not from or not from[1] then return end
    local from_email = from[1]['addr']:lower()

    local sig_dir = find_sig_dir(from_email)
    if not sig_dir then return end

    -- Read available signature parts
    local html_sig = read_file(sig_dir .. "/signature.html")
    local txt_sig  = read_file(sig_dir .. "/signature.txt")
    local logo_png = read_file(sig_dir .. "/logo.png")

    if not html_sig and not txt_sig then return end

    -- Inspect existing MIME structure
    local parts = task:get_parts()
    if not parts then return end

    local has_html = false
    local has_text = false
    for _, part in ipairs(parts) do
        local ct = part:get_content_type()
        if ct then
            if ct:lower():find("text/html") then has_html = true end
            if ct:lower():find("text/plain") then has_text = true end
        end
    end

    local cid = logo_png and make_cid(sig_dir) or nil

    -- ── Build signature injection ─────────────────────────────────────────────
    -- rspamd's mime modification API: we use set_text() on existing parts
    -- and inject the logo as a new inline attachment if present.

    for _, part in ipairs(parts) do
        local ct = (part:get_content_type() or ""):lower()

        -- TEXT/PLAIN part
        if ct:find("text/plain") and txt_sig then
            local body = tostring(part:get_content() or "")
            -- Append signature below quoted text (i.e. at the very end)
            local new_body = body .. "\r\n-- \r\n" .. txt_sig
            task:set_milter_reply({
                ['body_replace'] = {
                    [part:get_id()] = new_body
                }
            })
        end

        -- TEXT/HTML part
        if ct:find("text/html") and html_sig then
            local body = tostring(part:get_content() or "")
            local sig_html

            if logo_png and cid then
                -- Replace placeholder src in html sig with cid reference
                sig_html = html_sig:gsub('src="logo%.png"',
                                         'src="cid:' .. cid .. '"')
            else
                sig_html = html_sig
            end

            -- Insert signature just before </body>, fallback: append
            local new_body
            if body:lower():find("</body>") then
                new_body = body:gsub("(</body>)",
                    '<div class="postsible-sig">' .. sig_html .. '</div>%1', 1)
            else
                new_body = body ..
                    '<div class="postsible-sig">' .. sig_html .. '</div>'
            end

            task:set_milter_reply({
                ['body_replace'] = {
                    [part:get_id()] = new_body
                }
            })

            -- Attach logo as inline image if present
            if logo_png and cid then
                task:set_milter_reply({
                    ['add_part'] = {
                        content_type      = 'image/png',
                        content_id        = '<' .. cid .. '>',
                        content_transfer_encoding = 'base64',
                        content           = b64(logo_png),
                        disposition       = 'inline',
                        filename          = 'logo.png',
                    }
                })
            end
        end
    end

    rspamd_logger.debugm(N, task,
        "postsible-signature: appended signature for %s (dir: %s)",
        from_email, sig_dir)
end

-- ── register ──────────────────────────────────────────────────────────────────

rspamd_config:register_symbol({
    name     = 'POSTSIBLE_SIGNATURE',
    type     = 'postfilter',
    priority = 10,
    callback = signature_cb,
})
