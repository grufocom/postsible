<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(name) {
  const names = ['signature','users','domains','admins'];
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', names[i]===name));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id==='tab-'+name));
  const url = new URL(window.location);
  url.searchParams.set('tab', name);
  history.pushState({}, '', url);
}
(function(){
  const tab = new URL(window.location).searchParams.get('tab');
  if (tab && document.getElementById('tab-'+tab)) switchTab(tab);
})();

// ── Signature type tabs ───────────────────────────────────────────────────────
function initSigTabs() {
  document.querySelectorAll('#tab-signature .sig-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.sig;
      document.querySelectorAll('#tab-signature .sig-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('#tab-signature .sig-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`sig-${target}-panel`).classList.add('active');
    });
  });
  document.querySelectorAll('#tab-domains .sig-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.sig;
      document.querySelectorAll('#tab-domains .sig-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('#tab-domains .sig-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`${target}-panel`).classList.add('active');
    });
  });
}

// ── HTML preview ──────────────────────────────────────────────────────────────
function updateHtmlPreview() {
  const html = document.getElementById('html-editor').value;
  document.getElementById('html-preview').srcdoc =
    "<html><body style='font-family:sans-serif;padding:12px;margin:0'>" + html + "</body></html>";
}
function updateDomHtmlPreview() {
  const html = document.getElementById('dom-html-editor').value;
  document.getElementById('dom-html-preview').srcdoc =
    "<html><body style='font-family:sans-serif;padding:12px;margin:0'>" + html + "</body></html>";
}

// ── HTML ↔ Text sync ──────────────────────────────────────────────────────────
function htmlToPlain(html) {
  return html
    .replace(/<br\s*\/?>/gi, '\n')
    .replace(/<\/p>/gi, '\n\n')
    .replace(/<\/div>/gi, '\n')
    .replace(/<\/h[1-6]>/gi, '\n')
    .replace(/<li>/gi, '  • ')
    .replace(/<\/li>/gi, '\n')
    .replace(/<\/(td|th)>/gi, ' | ')
    .replace(/<\/(tr|thead|tbody)>/gi, '\n')
    .replace(/<[^>]*>/g, '')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}
function textToHtml(text) {
  return '<p>' + text.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>\n') + '</p>';
}
function syncTextFromHtml()    { document.getElementById('text-editor').value     = htmlToPlain(document.getElementById('html-editor').value); }
function syncHtmlFromText()    { document.getElementById('html-editor').value     = textToHtml(document.getElementById('text-editor').value); updateHtmlPreview(); }
function syncDomTextFromHtml() { document.getElementById('dom-text-editor').value = htmlToPlain(document.getElementById('dom-html-editor').value); }
function syncDomHtmlFromText() { document.getElementById('dom-html-editor').value = textToHtml(document.getElementById('dom-text-editor').value); updateDomHtmlPreview(); }

// ── Form submit: copy editor content into hidden inputs ───────────────────────
document.getElementById('sig-form').addEventListener('submit', function() {
  document.getElementById('sig_html_input').value = document.getElementById('html-editor').value;
  document.getElementById('sig_text_input').value = document.getElementById('text-editor').value;
});
<?php if ($show_tabs): ?>
const domForm = document.getElementById('dom-sig-form');
if (domForm) domForm.addEventListener('submit', function() {
  document.getElementById('dom_sig_html_input').value = document.getElementById('dom-html-editor').value;
  document.getElementById('dom_sig_text_input').value = document.getElementById('dom-text-editor').value;
});
<?php endif; ?>

// ── Logo preview ──────────────────────────────────────────────────────────────
function previewLogo(input) {
  if (!input.files || !input.files[0]) return;
  document.getElementById('upload-label').textContent = '📎 ' + input.files[0].name;
  const reader = new FileReader();
  reader.onload = e => { const img = document.getElementById('new-logo-preview'); img.src = e.target.result; img.style.display = 'block'; };
  reader.readAsDataURL(input.files[0]);
}
function previewDomLogo(input) {
  if (!input.files || !input.files[0]) return;
  document.getElementById('dom-upload-label').textContent = '📎 ' + input.files[0].name;
  const reader = new FileReader();
  reader.onload = e => { const img = document.getElementById('dom-new-logo-preview'); img.src = e.target.result; img.style.display = 'block'; };
  reader.readAsDataURL(input.files[0]);
}

initSigTabs();
</script>

