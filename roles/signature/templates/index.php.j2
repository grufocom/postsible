<script>
// ── Tab switching ──────────────────────────────────────────────────────────────
function switchTab(name) {
  const names = ['signature','users','domains','admins'];
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', names[i]===name));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id==='tab-'+name));
  const url = new URL(window.location);
  url.searchParams.set('tab', name);
  history.pushState({}, '', url);
}
(function(){
  const tab = new URL(window.location).searchParams.get('tab');
  if (tab && document.getElementById('tab-'+tab)) switchTab(tab);
})();

// ── Quill – user signature editor ─────────────────────────────────────────────
const quill = new Quill('#quill-editor', {
  theme: 'snow',
  modules: {
    toolbar: [
      ['bold','italic','underline','strike'],
      [{'color':[]},{'background':[]}],
      [{'font':[]},{'size':['small',false,'large','huge']}],
      [{'align':[]}],
      ['link','image'],
      ['clean']
    ]
  }
});

function updatePreview() {
  const html = quill.root.innerHTML;
  document.getElementById('sig_html_input').value = html;
  const frame = document.getElementById('sig-preview');
  frame.srcdoc = "<html><body style='font-family:sans-serif;padding:12px'>" + html + "</body></html>";
}
quill.on('text-change', () => { clearTimeout(quill._previewTimer); quill._previewTimer = setTimeout(updatePreview, 600); });

document.getElementById('sig-form').addEventListener('submit', function() {
  document.getElementById('sig_html_input').value = quill.root.innerHTML;
});

// ── Quill – domain signature editor ───────────────────────────────────────────
<?php if ($show_tabs): ?>
const domQuill = new Quill('#dom-quill-editor', {
  theme: 'snow',
  modules: {
    toolbar: [
      ['bold','italic','underline','strike'],
      [{'color':[]},{'background':[]}],
      [{'font':[]},{'size':['small',false,'large','huge']}],
      [{'align':[]}],
      ['link','image'],
      ['clean']
    ]
  }
});

function updateDomPreview() {
  const html = domQuill.root.innerHTML;
  document.getElementById('dom_sig_html_input').value = html;
  const frame = document.getElementById('dom-sig-preview');
  frame.srcdoc = "<html><body style='font-family:sans-serif;padding:12px'>" + html + "</body></html>";
}
domQuill.on('text-change', () => { clearTimeout(domQuill._previewTimer); domQuill._previewTimer = setTimeout(updateDomPreview, 600); });

document.getElementById('dom-sig-form').addEventListener('submit', function() {
  document.getElementById('dom_sig_html_input').value = domQuill.root.innerHTML;
});
<?php endif; ?>

// ── Logo preview helpers ───────────────────────────────────────────────────────
function previewLogo(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  document.getElementById('upload-label').textContent = '📎 ' + file.name;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('new-logo-preview');
    img.src = e.target.result;
    img.style.display = 'block';
  };
  reader.readAsDataURL(file);
}

function previewDomLogo(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  document.getElementById('dom-upload-label').textContent = '📎 ' + file.name;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('dom-new-logo-preview');
    img.src = e.target.result;
    img.style.display = 'block';
  };
  reader.readAsDataURL(file);
}
</script>
