// ══════════════════════════════════════════════════════════════════════════════
// Editor mode switcher  (WYSIWYG ↔ HTML source)
// ══════════════════════════════════════════════════════════════════════════════
const _editorState = { user: 'wysiwyg', dom: 'wysiwyg' };

function getQuill(prefix) { return prefix === 'user' ? quill : (typeof domQuill !== 'undefined' ? domQuill : null); }

function getEditorHtml(prefix) {
  if (_editorState[prefix] === 'source') {
    return document.getElementById(prefix + '-source-editor').value;
  }
  const q = getQuill(prefix);
  return q ? q.root.innerHTML : '';
}

function setEditorMode(prefix, mode) {
  const q        = getQuill(prefix);
  const wrap     = document.getElementById(prefix + '-editor-wrap');
  const srcArea  = document.getElementById(prefix + '-source-editor');
  const btnVisual = document.getElementById(prefix + '-btn-wysiwyg');
  const btnSource = document.getElementById(prefix + '-btn-source');
  const modeLabel = document.getElementById(prefix + '-mode-label');

  if (mode === 'source') {
    // Sync Quill → textarea
    if (q) srcArea.value = q.root.innerHTML;
    srcArea.classList.add('visible');
    wrap.classList.add('source-mode-active');
    btnVisual.classList.remove('active');
    btnSource.classList.add('active');
    modeLabel.textContent = 'HTML source mode';
  } else {
    // Sync textarea → Quill
    if (q && srcArea.value.trim() !== '') {
      q.clipboard.dangerouslyPasteHTML(srcArea.value);
    }
    srcArea.classList.remove('visible');
    wrap.classList.remove('source-mode-active');
    btnVisual.classList.add('active');
    btnSource.classList.remove('active');
    modeLabel.textContent = 'WYSIWYG mode';
  }
  _editorState[prefix] = mode;
}

// Live source → preview sync (debounced)
['user','dom'].forEach(pfx => {
  const ta = document.getElementById(pfx + '-source-editor');
  if (!ta) return;
  ta.addEventListener('input', () => {
    clearTimeout(ta._pt);
    ta._pt = setTimeout(() => {
      if (_editorState[pfx] === 'source') {
        const html = ta.value;
        const frameId = pfx === 'user' ? 'sig-preview' : 'dom-sig-preview';
        const frame = document.getElementById(frameId);
        if (frame) frame.srcdoc = "<html><body style='font-family:sans-serif;padding:12px'>" + html + "</body></html>";
      }
    }, 600);
  });
});

// ══════════════════════════════════════════════════════════════════════════════
// Table insert dialog
// ══════════════════════════════════════════════════════════════════════════════
let _tableTarget = 'user';
let _tableRows   = 0;
let _tableCols   = 0;

function buildTableGrid() {
  const grid = document.getElementById('table-grid');
  grid.innerHTML = '';
  for (let r = 1; r <= 6; r++) {
    for (let c = 1; c <= 8; c++) {
      const cell = document.createElement('div');
      cell.className = 'table-grid-cell';
      cell.dataset.r = r;
      cell.dataset.c = c;
      cell.addEventListener('mouseover', () => highlightGrid(r, c));
      cell.addEventListener('click',     () => selectGridSize(r, c));
      grid.appendChild(cell);
    }
  }
}

function highlightGrid(rows, cols) {
  _tableRows = rows; _tableCols = cols;
  document.querySelectorAll('.table-grid-cell').forEach(cell => {
    cell.classList.toggle('hovered', +cell.dataset.r <= rows && +cell.dataset.c <= cols);
  });
  document.getElementById('table-grid-label').textContent = rows + ' × ' + cols + ' table';
  document.getElementById('table-insert-btn').disabled = false;
}

function selectGridSize(rows, cols) {
  _tableRows = rows; _tableCols = cols;
  confirmInsertTable();
}

function openTableDialog(prefix) {
  _tableTarget = prefix;
  _tableRows = 0; _tableCols = 0;
  buildTableGrid();
  document.getElementById('table-grid-label').textContent = 'Hover to select size';
  document.getElementById('table-insert-btn').disabled = true;
  document.getElementById('table-dialog-overlay').classList.add('open');
}

function closeTableDialog(e) {
  if (!e || e.target === document.getElementById('table-dialog-overlay'))
    document.getElementById('table-dialog-overlay').classList.remove('open');
}

function confirmInsertTable() {
  if (!_tableRows || !_tableCols) return;
  document.getElementById('table-dialog-overlay').classList.remove('open');

  const rows = _tableRows, cols = _tableCols;

  if (_editorState[_tableTarget] === 'source') {
    // Insert into raw HTML textarea
    const ta = document.getElementById(_tableTarget + '-source-editor');
    const tableHtml = buildTableHtml(rows, cols);
    const pos = ta.selectionStart;
    ta.value = ta.value.slice(0, pos) + tableHtml + ta.value.slice(ta.selectionEnd);
    ta.selectionStart = ta.selectionEnd = pos + tableHtml.length;
    ta.dispatchEvent(new Event('input'));
    ta.focus();
  } else {
    // Insert into Quill via clipboard
    const q = getQuill(_tableTarget);
    if (!q) return;
    const tableHtml = buildTableHtml(rows, cols);
    const range = q.getSelection(true);
    const idx   = range ? range.index : q.getLength();
    q.clipboard.dangerouslyPasteHTML(idx, tableHtml);
    // Move cursor after table
    q.setSelection(idx + 1, 0);
  }
}

function buildTableHtml(rows, cols) {
  const cellStyle = 'border:1px solid #c8d0da;padding:6px 10px;min-width:60px;';
  let html = '<table style="border-collapse:collapse;width:100%;margin:8px 0"><tbody>';
  for (let r = 0; r < rows; r++) {
    html += '<tr>';
    for (let c = 0; c < cols; c++) {
      html += '<td style="' + cellStyle + '">&nbsp;</td>';
    }
    html += '</tr>';
  }
  html += '</tbody></table>';
  return html;
}

// ══════════════════════════════════════════════════════════════════════════════
// Logo preview helpers
// ══════════════════════════════════════════════════════════════════════════════
function previewLogo(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  document.getElementById('upload-label').textContent = '📎 ' + file.name;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('new-logo-preview');
    img.src = e.target.result;
    img.style.display = 'block';
  };
  reader.readAsDataURL(file);
}

function previewDomLogo(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  document.getElementById('dom-upload-label').textContent = '📎 ' + file.name;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('dom-new-logo-preview');
    img.src = e.target.result;
    img.style.display = 'block';
  };
  reader.readAsDataURL(file);
}
</script>

