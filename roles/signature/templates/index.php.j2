// {{ ansible_managed }}
/**
 * Postsible Signature Manager
 * Material Design inspired, Nextcloud blue palette
 * Analog to the Vacation Manager – same auth, same look & feel
 */

session_start();

// ─── Configuration ────────────────────────────────────────────────────────────
define('IMAP_HOST',        '{{ signature_imap_host }}');
define('IMAP_PORT',        {{ signature_imap_port }});
define('SIG_MANAGE',       '{{ signature_manage }}');
define('SIG_BASE_DIR',     '{{ signature_base_dir }}');
define('DB_HOST',          '{{ signature_db_host }}');
define('DB_NAME',          '{{ signature_db_name }}');
define('DB_USER',          '{{ signature_db_user }}');
define('DB_PASS',          '{{ signature_db_pass }}');
define('SESSION_TIMEOUT',  3600);
define('MAX_IMG_BYTES',    {{ signature_max_image_bytes }});
define('IMG_MAX_PX',       {{ signature_image_max_px }});
define('FALLBACK_DOMAINS', '{{ signature_fallback_domains | tojson }}');

// ─── Database ─────────────────────────────────────────────────────────────────
function db(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $pdo = new PDO(
            'mysql:host=' . DB_HOST . ';dbname=' . DB_NAME . ';charset=utf8mb4',
            DB_USER, DB_PASS,
            [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
             PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC]
        );
    }
    return $pdo;
}

// ─── IMAP auth ────────────────────────────────────────────────────────────────
function imap_authenticate(string $email, string $password): bool {
    $ctx = stream_context_create(['ssl' => [
        'verify_peer' => false, 'verify_peer_name' => false,
    ]]);
    $socket = @stream_socket_client(
        'ssl://' . IMAP_HOST . ':' . IMAP_PORT,
        $errno, $errstr, 10, STREAM_CLIENT_CONNECT, $ctx
    );
    if (!$socket) return false;
    fgets($socket, 1024);
    $tag  = 'A001';
    $user = str_replace(['"','\\'], ['\\"','\\\\'], $email);
    $pass = str_replace(['"','\\'], ['\\"','\\\\'], $password);
    fwrite($socket, "{$tag} LOGIN \"{$user}\" \"{$pass}\"\r\n");
    $response = '';
    while (!feof($socket)) {
        $line = fgets($socket, 1024);
        $response .= $line;
        if (strpos($line, $tag) === 0) break;
    }
    fclose($socket);
    return strpos($response, "{$tag} OK") !== false;
}

// ─── Session ──────────────────────────────────────────────────────────────────
function session_valid(): bool {
    if (empty($_SESSION['email']) || empty($_SESSION['ts'])) return false;
    if (time() - $_SESSION['ts'] > SESSION_TIMEOUT) { session_destroy(); return false; }
    $_SESSION['ts'] = time();
    return true;
}

function get_user_role(string $email): string {
    try {
        $stmt = db()->prepare('SELECT role FROM signature_admins WHERE email = ?');
        $stmt->execute([$email]);
        $row = $stmt->fetch();
        return $row ? $row['role'] : 'user';
    } catch (Exception $e) { return 'user'; }
}

function get_all_users(): array {
    try {
        $stmt = db()->query('SELECT email FROM virtual_users WHERE enabled=1 ORDER BY email');
        return $stmt->fetchAll(PDO::FETCH_COLUMN);
    } catch (Exception $e) { return []; }
}

function get_all_admins(): array {
    try {
        return db()->query(
            'SELECT email, role, granted_by, created_at FROM signature_admins ORDER BY role DESC, email'
        )->fetchAll();
    } catch (Exception $e) { return []; }
}
// ─── Signature file helpers ───────────────────────────────────────────────────
function sig_dir_user($email): string {
    if (is_array($email)) {
        $email = !empty($email) ? (string)$email[0] : '';
    }
    $email = (string)$email;
    if (empty($email)) {
        throw new InvalidArgumentException('Email address cannot be empty');
    }
    $email = trim($email);
    $email = preg_replace('/[^a-zA-Z0-9@._-]/', '', $email);
    if (empty($email) || !str_contains($email, '@')) {
        throw new InvalidArgumentException('Invalid email address');
    }
    return SIG_BASE_DIR . '/users/' . $email;
}

function sig_dir_domain($domain): string {
    if (is_array($domain)) {
        $domain = !empty($domain) ? (string)$domain[0] : '';
    }
    $domain = (string)$domain;
    if (empty($domain)) {
        throw new InvalidArgumentException('Domain cannot be empty');
    }
    $domain = trim($domain, '/\\');
    $domain = preg_replace('/[^a-zA-Z0-9.-]/', '', $domain);
    if (empty($domain)) {
        throw new InvalidArgumentException('Invalid domain name after sanitization');
    }
    return SIG_BASE_DIR . '/domains/' . $domain;
}

function read_sig(string $dir): array {
    if (empty($dir)) {
        return ['html' => '', 'txt' => '', 'logo' => false];
    }
    return [
        'html' => is_file($dir . '/signature.html') ? file_get_contents($dir . '/signature.html') : '',
        'txt'  => is_file($dir . '/signature.txt')  ? file_get_contents($dir . '/signature.txt')  : '',
        'logo' => is_file($dir . '/logo.png'),
    ];
}

function has_sig(string $dir): bool {
    if (empty($dir)) {
        return false;
    }
    return is_file($dir . '/signature.html') || is_file($dir . '/signature.txt');
}
function fallback_domains(): array {
    $decoded = json_decode(FALLBACK_DOMAINS, true);
    if (!is_array($decoded) || empty($decoded)) {
        return [];
    }
    $domains = [];
    foreach ($decoded as $item) {
        if (is_string($item)) {
            $domains[] = $item;
        } elseif (is_array($item) && isset($item['domain'])) {
            $domains[] = (string)$item['domain'];
        } elseif (is_array($item) && isset($item['name'])) {
            $domains[] = (string)$item['name'];
        } elseif (is_array($item) && !empty($item)) {
            $first = reset($item);
            if (is_string($first)) {
                $domains[] = $first;
            }
        }
    }
    $domains = array_unique($domains);
    $domains = array_filter($domains);
    sort($domains);
    return $domains;
}
function email_domain(string $email): string {
    return substr(strrchr($email, '@'), 1);
}

// ─── Image processing ─────────────────────────────────────────────────────────
function process_image(array $file, string $dest): array {
    if ($file['size'] > MAX_IMG_BYTES)
        return [false, 'Image too large (max ' . (MAX_IMG_BYTES/1024) . ' KB).'];

    $tmp  = $file['tmp_name'];
    $mime = mime_content_type($tmp);

    if ($mime === 'image/svg+xml') {
        if (!extension_loaded('imagick'))
            return [false, 'SVG upload requires the Imagick PHP extension. Please upload PNG/JPG instead.'];
        try {
            $im = new Imagick();
            $im->readImageBlob(file_get_contents($tmp));
            $im->setImageFormat('png');
            $im->resizeImage(IMG_MAX_PX, IMG_MAX_PX, Imagick::FILTER_LANCZOS, 1, true);
            $im->writeImage($dest);
            $im->destroy();
            return [true, ''];
        } catch (Exception $e) {
            return [false, 'SVG conversion failed: ' . $e->getMessage()];
        }
    }

    if (!in_array($mime, ['image/png', 'image/jpeg']))
        return [false, 'Unsupported image type. Please upload PNG, JPG or SVG.'];

    $src = ($mime === 'image/jpeg') ? imagecreatefromjpeg($tmp) : imagecreatefrompng($tmp);
    if (!$src) return [false, 'Could not read image file.'];

    $ow = imagesx($src); $oh = imagesy($src);
    $max = IMG_MAX_PX;
    if ($ow > $max || $oh > $max) {
        $ratio = $ow >= $oh ? $max / $ow : $max / $oh;
        $nw = (int)round($ow * $ratio);
        $nh = (int)round($oh * $ratio);
    } else {
        $nw = $ow; $nh = $oh;
    }

    $dst = imagecreatetruecolor($nw, $nh);
    imagealphablending($dst, false);
    imagesavealpha($dst, true);
    $trans = imagecolorallocatealpha($dst, 0, 0, 0, 127);
    imagefilledrectangle($dst, 0, 0, $nw, $nh, $trans);
    imagecopyresampled($dst, $src, 0, 0, 0, 0, $nw, $nh, $ow, $oh);
    imagedestroy($src);

    $ok = imagepng($dst, $dest, 6);
    imagedestroy($dst);

    return $ok ? [true, ''] : [false, 'Failed to write PNG.'];
}

// ─── sudo helper ──────────────────────────────────────────────────────────────
function run_sig_manage(array $args): array {
    foreach ($args as $arg) {
        if (preg_match('/[;&|`$<>\n\r]/', (string)$arg))
            return ['ok' => false, 'output' => 'Invalid characters in argument.'];
    }
    $cmd   = 'sudo ' . escapeshellcmd(SIG_MANAGE);
    $parts = array_map('escapeshellarg', $args);
    $full  = $cmd . ' ' . implode(' ', $parts) . ' 2>&1';
    exec($full, $output, $rc);
    return ['ok' => ($rc === 0), 'output' => implode("\n", $output)];
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function h(string $s): string { return htmlspecialchars($s, ENT_QUOTES, 'UTF-8'); }
function validate_email(string $e): bool { return (bool)filter_var($e, FILTER_VALIDATE_EMAIL); }
function validate_domain(string $d): bool {
    return (bool)preg_match('/^[a-zA-Z0-9.\-]+\.[a-zA-Z]{2,}$/', $d);
}

// ─── Request routing ──────────────────────────────────────────────────────────
$action  = $_POST['action']  ?? $_GET['action']  ?? '';
$message = '';
$error   = '';

// LOGIN
if ($action === 'login') {
    $email    = trim($_POST['email']    ?? '');
    $password = trim($_POST['password'] ?? '');
    if (!validate_email($email)) {
        $error = 'Please enter a valid email address.';
    } elseif (empty($password)) {
        $error = 'Please enter your password.';
    } elseif (imap_authenticate($email, $password)) {
        session_regenerate_id(true);
        $_SESSION['email'] = $email;
        $_SESSION['role']  = get_user_role($email);
        $_SESSION['ts']    = time();
        header('Location: ?'); exit;
    } else {
        $error = 'Invalid email address or password.';
    }
}
if ($action === 'logout') { session_destroy(); header('Location: ?'); exit; }

// ── Authenticated actions ─────────────────────────────────────────────────────
if (session_valid()) {
    $me   = $_SESSION['email'];
    $role = $_SESSION['role'];

    if ($action === 'save_signature') {
        $scope  = $_POST['scope'] ?? 'user';
        $target = ($scope === 'domain')
            ? trim($_POST['target_domain'] ?? '')
            : (($role !== 'user') ? trim($_POST['target_email'] ?? $me) : $me);

        $html_raw = trim($_POST['sig_html'] ?? '');
        // Convert HTML to plain text, handling tables and block elements cleanly
        $txt_tmp = $html_raw;
        // Table cell/row separators → readable whitespace BEFORE strip_tags
        $txt_tmp = preg_replace('/<\/th>(\s*<th[^>]*>)/i', ' | ', $txt_tmp);
        $txt_tmp = preg_replace('/<\/td>(\s*<td[^>]*>)/i', ' | ', $txt_tmp);
        $txt_tmp = str_replace(
            ['<tr', '<TR', '</tr>', '</TR>', '</th>', '</TD>', '</td>', '</TH>',
             '<table', '<TABLE', '</table>', '</TABLE>',
             '<thead', '<THEAD', '</thead>', '</THEAD>',
             '<tbody', '<TBODY', '</tbody>', '</TBODY>',
             '<tfoot', '<TFOOT', '</tfoot>', '</TFOOT>',
             '<br>', '<br/>', '<br />', '<BR>', '<BR/>',
             '</p>', '</P>', '</div>', '</DIV>'],
            ["\n<tr", "\n<TR", "\n", "\n", "\n", "\n", "\n", "\n",
             "\n<table", "\n<TABLE", "\n", "\n",
             "\n<thead", "\n<THEAD", "\n", "\n",
             "\n<tbody", "\n<TBODY", "\n", "\n",
             "\n<tfoot", "\n<TFOOT", "\n", "\n",
             "\n", "\n", "\n", "\n", "\n",
             "\n", "\n", "\n", "\n"],
            $txt_tmp
        );
        $txt_tmp = strip_tags($txt_tmp);
        // Collapse runs of blank lines (more than 2 in a row → 1 blank line)
        $txt_tmp = preg_replace('/\n{3,}/', "\n\n", $txt_tmp);
        $txt_raw = trim($txt_tmp);

        if (empty($html_raw)) {
            $error = 'Signature HTML cannot be empty.';
        } elseif ($scope === 'domain' && !validate_domain($target)) {
            $error = 'Invalid domain name.';
        } elseif ($scope === 'user' && !validate_email($target)) {
            $error = 'Invalid email address.';
        } else {
            $tmp_html = tempnam(sys_get_temp_dir(), 'sig_html_');
            $tmp_txt  = tempnam(sys_get_temp_dir(), 'sig_txt_');
            file_put_contents($tmp_html, $html_raw);
            file_put_contents($tmp_txt,  $txt_raw);

            $tmp_img = '';
            if (!empty($_FILES['logo']['name']) && $_FILES['logo']['error'] === UPLOAD_ERR_OK) {
                $tmp_img_dest = tempnam(sys_get_temp_dir(), 'sig_img_');
                [$img_ok, $img_err] = process_image($_FILES['logo'], $tmp_img_dest);
                if (!$img_ok) {
                    $error = $img_err;
                } else {
                    $tmp_img = $tmp_img_dest;
                }
            }

            if (!$error) {
                $cmd = ($scope === 'domain') ? 'save-domain' : 'save-user';
                $args = [$cmd, $target, $tmp_html, $tmp_txt];
                if ($tmp_img) $args[] = $tmp_img;

                $result = run_sig_manage($args);
                if ($result['ok']) {
                    $message = ($scope === 'domain')
                        ? "Domain signature saved for {$target}."
                        : "Signature saved for {$target}.";
                } else {
                    $error = 'Error: ' . h($result['output']);
                }
            }

            @unlink($tmp_html);
            @unlink($tmp_txt);
            if ($tmp_img) @unlink($tmp_img);
        }
    }

    if ($action === 'delete_signature') {
        $scope  = $_POST['scope'] ?? 'user';
        $target = ($scope === 'domain')
            ? trim($_POST['target_domain'] ?? '')
            : (($role !== 'user') ? trim($_POST['target_email'] ?? $me) : $me);

        $cmd    = ($scope === 'domain') ? 'delete-domain' : 'delete-user';
        $result = run_sig_manage([$cmd, $target]);
        if ($result['ok']) {
            $message = "Signature deleted for {$target}.";
        } else {
            $error = 'Error: ' . h($result['output']);
        }
    }

    if ($action === 'add_admin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) { $error = 'Invalid email.'; }
        else {
            $r = run_sig_manage(['add-admin', $target, '--granted-by', $me]);
            $r['ok'] ? $message = "Admin granted to {$target}."
                     : $error   = 'Error: ' . h($r['output']);
        }
    }
    if ($action === 'remove_admin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) { $error = 'Invalid email.'; }
        else {
            $r = run_sig_manage(['remove-admin', $target]);
            $r['ok'] ? $message = "Admin revoked from {$target}."
                     : $error   = 'Error: ' . h($r['output']);
        }
    }
    if ($action === 'set_superadmin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) { $error = 'Invalid email.'; }
        else {
            $r = run_sig_manage(['set-superadmin', $target]);
            $r['ok'] ? $message = "{$target} is now superadmin."
                     : $error   = 'Error: ' . h($r['output']);
        }
    }
}

// ─── Determine what to show ───────────────────────────────────────────────────
if (session_valid()) {
    $me   = $_SESSION['email'];
    $role = $_SESSION['role'];

    $view_email = ($role !== 'user')
        ? (trim($_GET['view'] ?? '') ?: $me)
        : $me;

    $view_domain = trim($_GET['domain'] ?? '');

    $user_sig_dir = sig_dir_user($view_email);
    $user_sig     = read_sig($user_sig_dir);
    $has_user_sig = has_sig($user_sig_dir);

    $edit_html = $user_sig['html'];
    $edit_from_fallback = false;
    if (!$has_user_sig) {
        $dom = email_domain($view_email);
        $dom_dir = sig_dir_domain($dom);
        if (has_sig($dom_dir)) {
            $dom_sig = read_sig($dom_dir);
            $edit_html = $dom_sig['html'];
            $edit_from_fallback = true;
        }
    }
}
