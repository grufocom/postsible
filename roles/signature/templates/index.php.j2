.editor-mode-bar{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--surface2);border:1.5px solid var(--border);
  border-top:none; /* sits below toolbar */
  padding:4px 8px;font-size:12px;color:var(--text-muted)}
.editor-mode-bar .mode-btns{display:flex;gap:4px}
.mode-btn{padding:3px 10px;border-radius:4px;border:1.5px solid var(--border);
  background:var(--surface);cursor:pointer;font-size:12px;font-weight:600;
  font-family:inherit;color:var(--text-muted);transition:all .15s}
.mode-btn.active{background:var(--nc-blue);border-color:var(--nc-blue);color:#fff}
.mode-btn:hover:not(.active){background:var(--nc-blue-bg);border-color:var(--nc-blue);color:var(--nc-blue)}

.html-source-editor{
  display:none;width:100%;min-height:220px;
  border:1.5px solid var(--border);border-top:none;
  border-bottom-left-radius:var(--radius);border-bottom-right-radius:var(--radius);
  padding:12px;font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace;
  font-size:13px;line-height:1.6;color:var(--text);background:#fafbfc;
  resize:vertical;outline:none;tab-size:2}
.html-source-editor:focus{border-color:var(--nc-blue);box-shadow:0 0 0 3px rgba(0,130,201,.10)}
.html-source-editor.visible{display:block}

/* When source mode active: hide Quill container but keep toolbar */
.source-mode-active .ql-container{display:none}
/* Round bottom corners of toolbar when source editor is shown */
.source-mode-active .ql-toolbar{border-bottom-left-radius:0;border-bottom-right-radius:0}

/* ── Table insert dialog ──────────────────────────────────────────────────── */
.table-dialog-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);
  z-index:9999;align-items:center;justify-content:center}
.table-dialog-overlay.open{display:flex}
.table-dialog{background:var(--surface);border-radius:var(--radius);
  box-shadow:var(--shadow-lg);padding:24px;width:320px;max-width:95vw}
.table-dialog h3{font-size:15px;font-weight:700;margin-bottom:16px;
  display:flex;align-items:center;gap:8px}
.table-grid{display:grid;grid-template-columns:repeat(8,28px);gap:3px;margin-bottom:14px}
.table-grid-cell{width:28px;height:28px;border:1.5px solid var(--border);border-radius:3px;
  cursor:pointer;transition:background .1s,border-color .1s;background:var(--surface)}
.table-grid-cell.hovered{background:var(--nc-blue-bg);border-color:var(--nc-blue)}
.table-grid-label{font-size:13px;color:var(--text-muted);margin-bottom:14px;min-height:18px}
.table-dialog-actions{display:flex;gap:8px;justify-content:flex-end}

/* ── Quill table styles (rendered output) ────────────────────────────────── */
.ql-editor table{border-collapse:collapse;width:100%;margin:8px 0}
.ql-editor td,.ql-editor th{
  border:1px solid #c8d0da;padding:6px 10px;min-width:60px;vertical-align:top}
.ql-editor th{background:var(--nc-blue-bg);font-weight:700}

/* Preview iframe */
.preview-wrap{border:1.5px solid var(--border);border-radius:var(--radius);
  overflow:hidden;background:#fff}
.preview-wrap iframe{width:100%;height:280px;border:none;display:block}

/* Logo preview */
.logo-preview{max-height:80px;max-width:240px;border-radius:4px;
  border:1px solid var(--border);padding:4px;background:#fff;margin-top:8px}

/* Upload area */
.upload-area{border:2px dashed var(--border);border-radius:var(--radius);
  padding:16px;text-align:center;cursor:pointer;transition:border-color .15s;
  font-size:13px;color:var(--text-muted)}
.upload-area:hover{border-color:var(--nc-blue);color:var(--nc-blue)}
.upload-area input[type=file]{display:none}
</style>
</head>
