-- /etc/rspamd/plugins.d/footer.lua
-- Managed by Ansible (roles/signature) — do not edit manually.
--
-- Appends per-user or per-domain HTML/plain-text signatures to outbound mail.
-- Runs as a prefilter at priority 10 — executes BEFORE DKIM signing so that
-- body hashes remain valid at the recipient's end.
--
-- Signature file locations:
--   Per-user:   {{ signature_base_dir }}/users/<email>/signature.{html,txt}
--   Per-domain: {{ signature_base_dir }}/domains/<domain>/signature.{html,txt}

local rspamd_logger = require "rspamd_logger"
local lua_mime      = require "lua_mime"
local rspamd_text   = require "rspamd_text"

rspamd_logger.warnx("footer: loading final version")

local function read_signature(user)
    local signature_dir = "{{ signature_base_dir }}/users/" .. user
    local f
    local html_content, txt_content = nil, nil
    f = io.open(signature_dir .. "/signature.html", "r")
    if f then html_content = f:read("*all"); f:close() end
    f = io.open(signature_dir .. "/signature.txt", "r")
    if f then txt_content = f:read("*all"); f:close() end
    return html_content, txt_content
end

local function footer_callback(task)
    local user = task:get_user()
    if not user then return false end

    local footer_html, footer_plain = read_signature(user)
    if not footer_html and not footer_plain then return false end

    rspamd_logger.infox(task, "footer: appending signature for %s", user)

    local rewrite = lua_mime.add_text_footer(task, footer_html, footer_plain)
    if not rewrite or not rewrite.out then
        rspamd_logger.warnx(task, "footer: add_text_footer failed")
        return false
    end

    -- Build the new Content-Type / CTE values (if rewrite requires it)
    local new_ct_value, new_cte_value
    if rewrite.need_rewrite_ct then
        if rewrite.new_ct then
            new_ct_value = string.format('%s/%s; charset=utf-8',
                rewrite.new_ct.type, rewrite.new_ct.subtype)
        end
        if rewrite.new_cte then
            new_cte_value = rewrite.new_cte
        end
    end

    -- rewrite.out contains the rewritten body — convert elements to rspamd_text chunks
    -- Each element is one of:
    --   string        -> use directly as rspamd_text
    --   {data, bool}  -> data is rspamd_text or string (bool = already encoded)
    --   rspamd_text   -> use directly
    local parts = {}

    local nl = (task:get_newlines_type() == 'lf') and '\n' or '\r\n'

    -- Collect original headers, replacing CT/CTE inline where needed
    -- (task:set_header() does not exist in rspamd_proxy context)
    task:headers_foreach(function(name, hdr)
        local lname = name:lower()
        if lname == 'content-length' then
            -- Drop Content-Length — body length changes after footer insertion
            return
        elseif lname == 'content-type' and new_ct_value then
            -- Replace with updated Content-Type
            parts[#parts + 1] = rspamd_text.fromstring(
                'Content-Type: ' .. new_ct_value .. nl)
        elseif lname == 'content-transfer-encoding' and new_cte_value then
            -- Replace with updated Content-Transfer-Encoding
            parts[#parts + 1] = rspamd_text.fromstring(
                'Content-Transfer-Encoding: ' .. new_cte_value .. nl)
        else
            -- hdr.raw includes the trailing CRLF already
            parts[#parts + 1] = rspamd_text.fromstring(hdr.raw)
        end
    end, {full = true})

    -- Blank line separating headers from body
    parts[#parts + 1] = rspamd_text.fromstring(nl)

    -- Body from rewrite.out — each element gets an explicit trailing newline
    for _, o in ipairs(rewrite.out) do
        if type(o) == 'table' then
            -- {content, already_encoded_bool}
            local data = o[1]
            if type(data) == 'userdata' then
                parts[#parts + 1] = data
            elseif type(data) == 'string' then
                parts[#parts + 1] = rspamd_text.fromstring(data)
            end
            parts[#parts + 1] = rspamd_text.fromstring(nl)
        elseif type(o) == 'userdata' then
            parts[#parts + 1] = o
            parts[#parts + 1] = rspamd_text.fromstring(nl)
        elseif type(o) == 'string' then
            if o == '' then
                -- Empty string = deliberate blank line (MIME part separator)
                parts[#parts + 1] = rspamd_text.fromstring(nl)
            else
                parts[#parts + 1] = rspamd_text.fromstring(o)
                parts[#parts + 1] = rspamd_text.fromstring(nl)
            end
        end
    end

    local ok, err = pcall(function()
        task:set_message(rspamd_text.fromtable(parts))
    end)

    if ok then
        rspamd_logger.infox(task, "footer: success for %s", user)
        return true
    else
        rspamd_logger.warnx(task, "footer: set_message error: %s", tostring(err))
        return false
    end
end

rspamd_config:register_symbol({
    name     = 'FOOTER',
    type     = 'prefilter',
    callback = footer_callback,
    priority = 10,
})

rspamd_logger.warnx("footer: final version registered")
