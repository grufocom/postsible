<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Postsible Tools</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #f5f7fa;
    width: 260px;
    padding: 0;
  }
  .header {
    background: #0082c9;
    color: #fff;
    padding: 14px 16px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .header-icon {
    width: 28px; height: 28px;
    background: rgba(255,255,255,.2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
  }
  .header-title { font-size: 14px; font-weight: 700; }
  .header-sub   { font-size: 11px; opacity: .75; margin-top: 1px; }

  .menu { padding: 10px; display: flex; flex-direction: column; gap: 8px; }

  .tool-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: #fff;
    border: 1.5px solid #dde3ea;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    color: #1a1f2e;
    transition: border-color .15s, box-shadow .15s;
    width: 100%;
    font-family: inherit;
  }
  .tool-btn:hover {
    border-color: #0082c9;
    box-shadow: 0 2px 8px rgba(0,130,201,.15);
  }
  .tool-btn-icon {
    font-size: 22px;
    line-height: 1;
    flex-shrink: 0;
  }
  .tool-btn-text { text-align: left; }
  .tool-btn-title { font-size: 13px; font-weight: 600; }
  .tool-btn-desc  { font-size: 11px; color: #6b7280; margin-top: 2px; }

  .footer {
    padding: 8px 12px;
    font-size: 10px;
    color: #9ca3af;
    text-align: center;
    border-top: 1px solid #eee;
  }
</style>
</head>
<body>
<div class="header">
  <div class="header-icon">P</div>
  <div>
    <div class="header-title">Postsible Tools</div>
    <div class="header-sub">Mail server self-service</div>
  </div>
</div>

<div class="menu">
  <button class="tool-btn" id="btn-vacation">
    <span class="tool-btn-icon">✈️</span>
    <div class="tool-btn-text">
      <div class="tool-btn-title">Vacation/Forwarding Manager</div>
      <div class="tool-btn-desc">Set out-of-office auto-replies</div>
    </div>
  </button>

  <button class="tool-btn" id="btn-signature">
    <span class="tool-btn-icon">✍️</span>
    <div class="tool-btn-text">
      <div class="tool-btn-title">Signature Manager</div>
      <div class="tool-btn-desc">Edit your email signature</div>
    </div>
  </button>
</div>

<div class="footer">{{ common_hostname }}</div>

<script src="popup.js"></script>
</body>
</html>
