# /etc/sudoers.d/postsible-signature
# Managed by Ansible (roles/signature) — do not edit manually.
#
# Allow the PHP-FPM worker to call signature-manage as root (no password).
# The script itself validates all inputs strictly.

Defaults!{{ signature_manage }} !requiretty
{{ signature_webserver_user }} ALL=(root) NOPASSWD: {{ signature_manage }}
