# {{ ansible_managed }}
# Dovecot SSL configuration (Dovecot 2.4.1)
ssl = {{ dovecot_ssl }}

# Primary certificate (default / fallback)
ssl_server_cert_file = {{ dovecot_ssl_cert }}
ssl_server_key_file = {{ dovecot_ssl_key }}

# SNI: per-hostname certificates for additional domains
{% for domain in mail_virtual_domains %}
{% if domain.mail_hostname is defined and domain.mail_hostname != postfix_myhostname %}
local_name {{ domain.mail_hostname }} {
  ssl_server_cert_file = {{ domain.ssl_cert | default('/etc/letsencrypt/live/' + domain.mail_hostname + '/fullchain.pem') }}
  ssl_server_key_file  = {{ domain.ssl_key  | default('/etc/letsencrypt/live/' + domain.mail_hostname + '/privkey.pem') }}
}
{% endif %}
{% endfor %}

# SSL protocols and ciphers (modern, secure)
ssl_min_protocol = {{ dovecot_ssl_min_protocol }}
ssl_cipher_list = {{ dovecot_ssl_cipher_list }}
ssl_cipher_suites = {{ dovecot_ssl_cipher_suites }}
ssl_server_prefer_ciphers = {{ 'server' if dovecot_ssl_prefer_server_ciphers else 'no' }}

# DH parameters
ssl_server_dh_file = {{ dovecot_ssl_dh }}

# Dovecot 2.4.1: ssl_options wurde entfernt, Kompression ist standardmäßig deaktiviert
