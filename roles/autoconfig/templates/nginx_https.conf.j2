# {{ ansible_managed }}
# autoconfig.{{ item.domain }} – HTTPS
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name autoconfig.{{ item.domain }};

    ssl_certificate     /etc/letsencrypt/live/autoconfig.{{ item.domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/autoconfig.{{ item.domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/autoconfig.{{ item.domain }}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL_ac_{{ item.domain | replace('.','_') }}:5m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 8.8.4.4 valid=300s;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    access_log /var/log/nginx/autoconfig-{{ item.domain }}-https-access.log;
    error_log  /var/log/nginx/autoconfig-{{ item.domain }}-https-error.log;

    root /var/www/autoconfig/{{ item.domain }};

    # Thunderbird autoconfig
    location /mail/config-v1.1.xml {
        default_type "application/xml";
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "public, max-age=3600" always;
        try_files $uri =404;
    }

    location /.well-known/autoconfig/mail/ {
        default_type "application/xml";
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "public, max-age=3600" always;
    }

{% if autoconfig_enable_autodiscover | default(true) %}
    # Microsoft Autodiscover (served here too as fallback)
    location ~* ^/autodiscover/autodiscover\.xml$ {
        default_type "application/xml";
        add_header Access-Control-Allow-Origin "*" always;
        try_files /autodiscover/autodiscover.xml =404;
    }
{% endif %}

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
        try_files $uri =404;
    }

    location /health {
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }
}
