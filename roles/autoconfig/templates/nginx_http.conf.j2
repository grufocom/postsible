# {{ ansible_managed }}
# autoconfig.{{ item.domain }} – HTTP (ACME challenge + redirect)
server {
    listen 80;
    listen [::]:80;
    server_name autoconfig.{{ item.domain }};

    access_log /var/log/nginx/autoconfig-{{ item.domain }}-http-access.log;
    error_log  /var/log/nginx/autoconfig-{{ item.domain }}-http-error.log;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
        try_files $uri =404;
    }

    # Serve autoconfig over HTTP too (some clients don't follow redirects)
    location /mail/config-v1.1.xml {
        root /var/www/autoconfig/{{ item.domain }};
        default_type "application/xml";
        add_header Access-Control-Allow-Origin "*";
    }

    location /.well-known/autoconfig/mail/ {
        root /var/www/autoconfig/{{ item.domain }};
        default_type "application/xml";
        add_header Access-Control-Allow-Origin "*";
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}
