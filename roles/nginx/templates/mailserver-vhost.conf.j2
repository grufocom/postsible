# {{ ansible_managed }}
# nginx vhost for {{ vdomain.mx_hostname }} (domain: {{ vdomain.domain }})
# Generated by Postsible – do not edit manually

# ── HTTP → HTTPS redirect + ACME challenge ────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name {{ vdomain.mx_hostname }};

    access_log /var/log/nginx/{{ vdomain.mx_hostname }}-http-access.log main;
    error_log  /var/log/nginx/{{ vdomain.mx_hostname }}-http-error.log;

    # Let's Encrypt ACME challenge (certbot webroot)
    location ^~ /.well-known/acme-challenge/ {
        root {{ certbot_webroot }};
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ vdomain.mx_hostname }};

    # Document root
    root /var/www/html;
    index index.html;

    # SSL – path is identical for LE and self-signed
    ssl_certificate     {{ certbot_cert_path }}/{{ vdomain.mx_hostname }}/fullchain.pem;
    ssl_certificate_key {{ certbot_cert_path }}/{{ vdomain.mx_hostname }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL_{{ vdomain.mx_hostname | replace('.','_') }}:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # OCSP stapling – only meaningful with real LE certs, not self-signed.
    # Controlled via nginx_ssl_stapling var (default true).
    # Set to false in vars.yml while self-signed certs are active to suppress warnings.
    {% if nginx_ssl_stapling | default(true) %}
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 8.8.4.4 valid=300s;
    resolver_timeout 5s;
    {% endif %}

    # Security headers
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;

    # Logging
    access_log /var/log/nginx/{{ vdomain.mx_hostname }}-https-access.log main;
    error_log  /var/log/nginx/{{ vdomain.mx_hostname }}-https-error.log;

    # ACME challenge (for renewals while HTTPS is active)
    location ^~ /.well-known/acme-challenge/ {
        root {{ certbot_webroot }};
        default_type "text/plain";
        try_files $uri =404;
    }

    # Rspamd WebUI (available on all domains)
    location /rspamd/ {
        proxy_pass http://127.0.0.1:{{ nginx_rspamd_port | default(11334) }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Health check
    location /health {
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    # Default root redirect
    location = / {
        return 301 /wm/;
    }

