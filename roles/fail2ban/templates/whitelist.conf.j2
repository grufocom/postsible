# Fail2ban whitelist configuration
# Managed by Ansible - DO NOT EDIT MANUALLY

[DEFAULT]
# Whitelisted IPs from ufw_ssh_trusted_ips
ignoreip = 127.0.0.1/8 ::1
{% if ufw_ssh_trusted_ips | default([]) %}
{% for ip_entry in ufw_ssh_trusted_ips %}
           {{ ip_entry.ip if ip_entry is mapping else ip_entry }}  {# {% if ip_entry.comment is defined %} # {{ ip_entry.comment }}{% endif %} #}
{% endfor %}
{% endif %}
{% if fail2ban_additional_whitelist | default([]) %}
{% for ip in fail2ban_additional_whitelist %}
           {{ ip }}
{% endfor %}
{% endif %}
