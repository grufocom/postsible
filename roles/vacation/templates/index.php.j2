// {{ ansible_managed }}
/**
 * Postsible Vacation Manager
 * Material Design inspired, Nextcloud blue palette
 * Authenticates users via IMAP against Dovecot
 */

session_start();

// ─── Configuration ────────────────────────────────────────────────────────────
define('IMAP_HOST',      '{{ vacation_imap_host }}');
define('IMAP_PORT',      {{ vacation_imap_port }});
define('MAILDB_MANAGE',  '{{ vacation_maildb_manage }}');
define('DB_HOST',        '{{ vacation_db_host }}');
define('DB_NAME',        '{{ vacation_db_name }}');
define('DB_USER',        '{{ vacation_db_user }}');
define('DB_PASS',        '{{ vacation_db_pass }}');
define('SESSION_TIMEOUT', 3600);

// ─── Database connection ───────────────────────────────────────────────────────
function db(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $pdo = new PDO(
            'mysql:host=' . DB_HOST . ';dbname=' . DB_NAME . ';charset=utf8mb4',
            DB_USER, DB_PASS,
            [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
             PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC]
        );
    }
    return $pdo;
}

// ─── IMAP authentication ───────────────────────────────────────────────────────
function imap_authenticate(string $email, string $password): bool {
    $host = IMAP_HOST;
    $port = IMAP_PORT;

    $ctx = stream_context_create(['ssl' => [
        'verify_peer'      => false,
        'verify_peer_name' => false,
    ]]);
    $socket = @stream_socket_client(
        "ssl://{$host}:{$port}", $errno, $errstr, 10,
        STREAM_CLIENT_CONNECT, $ctx
    );
    if (!$socket) return false;

    fgets($socket, 1024); // greeting

    $tag  = 'A001';
    $user = str_replace(['"', '\\'], ['\"', '\\\\'], $email);
    $pass = str_replace(['"', '\\'], ['\"', '\\\\'], $password);
    fwrite($socket, "{$tag} LOGIN \"{$user}\" \"{$pass}\"\r\n");

    $response = '';
    while (!feof($socket)) {
        $line = fgets($socket, 1024);
        $response .= $line;
        if (strpos($line, $tag) === 0) break;
    }
    fclose($socket);

    return strpos($response, "{$tag} OK") !== false;
}

// ─── Session helpers ───────────────────────────────────────────────────────────
function session_valid(): bool {
    if (empty($_SESSION['email']) || empty($_SESSION['ts'])) return false;
    if (time() - $_SESSION['ts'] > SESSION_TIMEOUT) {
        session_destroy();
        return false;
    }
    $_SESSION['ts'] = time();
    return true;
}

function get_user_role(string $email): string {
    try {
        $stmt = db()->prepare('SELECT role FROM vacation_admins WHERE email = ?');
        $stmt->execute([$email]);
        $row = $stmt->fetch();
        return $row ? $row['role'] : 'user';
    } catch (Exception $e) {
        return 'user';
    }
}

function get_all_users(): array {
    try {
        $stmt = db()->query('SELECT email FROM virtual_users WHERE enabled=1 ORDER BY email');
        return $stmt->fetchAll(PDO::FETCH_COLUMN);
    } catch (Exception $e) {
        return [];
    }
}

function get_all_admins(): array {
    try {
        $stmt = db()->query(
            'SELECT email, role, granted_by, created_at
             FROM vacation_admins ORDER BY role DESC, email'
        );
        return $stmt->fetchAll();
    } catch (Exception $e) {
        return [];
    }
}

function get_vacation_status(string $email): ?array {
    try {
        $stmt = db()->prepare(
            'SELECT active, date_from, date_to, subject, message, updated_at
             FROM vacation_status WHERE email = ?'
        );
        $stmt->execute([$email]);
        return $stmt->fetch() ?: null;
    } catch (Exception $e) {
        return null;
    }
}

// ─── Run maildb-manage via sudo ────────────────────────────────────────────────
function run_maildb(array $args): array {
    foreach ($args as $arg) {
        if (preg_match('/[;&|`$<>\n\r]/', $arg)) {
            return ['ok' => false, 'output' => 'Invalid characters in argument.'];
        }
    }
    $cmd   = 'sudo ' . escapeshellcmd(MAILDB_MANAGE);
    $parts = array_map('escapeshellarg', $args);
    $full  = $cmd . ' ' . implode(' ', $parts) . ' 2>&1';
    exec($full, $output, $rc);
    return ['ok' => ($rc === 0), 'output' => implode("\n", $output)];
}

// ─── Helpers ───────────────────────────────────────────────────────────────────
function h(string $s): string {
    return htmlspecialchars($s, ENT_QUOTES, 'UTF-8');
}
function validate_date(string $d): bool {
    $dt = DateTime::createFromFormat('Y-m-d', $d);
    return $dt && $dt->format('Y-m-d') === $d;
}
function validate_email(string $e): bool {
    return (bool) filter_var($e, FILTER_VALIDATE_EMAIL);
}

// ─── Request routing ───────────────────────────────────────────────────────────
$action  = $_POST['action']  ?? $_GET['action']  ?? '';
$message = '';
$error   = '';

if ($action === 'login') {
    $email    = trim($_POST['email']    ?? '');
    $password = trim($_POST['password'] ?? '');
    if (!validate_email($email)) {
        $error = 'Please enter a valid email address.';
    } elseif (empty($password)) {
        $error = 'Please enter your password.';
    } elseif (imap_authenticate($email, $password)) {
        session_regenerate_id(true);
        $_SESSION['email'] = $email;
        $_SESSION['role']  = get_user_role($email);
        $_SESSION['ts']    = time();
        header('Location: ?');
        exit;
    } else {
        $error = 'Invalid email address or password.';
    }
}

if ($action === 'logout') {
    session_destroy();
    header('Location: ?');
    exit;
}

if (session_valid()) {
    $me   = $_SESSION['email'];
    $role = $_SESSION['role'];

    if ($action === 'set_vacation') {
        $target  = ($role !== 'user') ? trim($_POST['target_email'] ?? $me) : $me;
        $dfrom   = trim($_POST['date_from'] ?? '');
        $dto     = trim($_POST['date_to']   ?? '');
        $subject = trim($_POST['subject']   ?? '');
        $msg     = trim($_POST['message']   ?? '');

        if (!validate_date($dfrom) || !validate_date($dto)) {
            $error = 'Please enter valid dates (YYYY-MM-DD).';
        } elseif ($dfrom > $dto) {
            $error = 'Start date must be before end date.';
        } elseif (empty($subject) || empty($msg)) {
            $error = 'Subject and message are required.';
        } elseif (!validate_email($target)) {
            $error = 'Invalid target email.';
        } else {
            $result = run_maildb([
                'set-vacation', $target,
                '--from', $dfrom, '--to', $dto,
                '--subject', $subject, '--message', $msg,
            ]);
            if ($result['ok']) {
                $message = "Vacation reply set for {$target}.";
            } else {
                $error = 'Error: ' . h($result['output']);
            }
        }
    }

    if ($action === 'disable_vacation') {
        $target = ($role !== 'user') ? trim($_POST['target_email'] ?? $me) : $me;
        if (!validate_email($target)) {
            $error = 'Invalid target email.';
        } else {
            $result = run_maildb(['disable-vacation', $target]);
            if ($result['ok']) {
                $message = "Vacation reply disabled for {$target}.";
            } else {
                $error = 'Error: ' . h($result['output']);
            }
        }
    }

    if ($action === 'add_admin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) {
            $error = 'Invalid email address.';
        } else {
            $result = run_maildb(['add-vacation-admin', $target, '--granted-by', $me]);
            $result['ok'] ? $message = "Admin role granted to {$target}."
                          : $error   = 'Error: ' . h($result['output']);
        }
    }

    if ($action === 'remove_admin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) {
            $error = 'Invalid email address.';
        } else {
            $result = run_maildb(['remove-vacation-admin', $target]);
            $result['ok'] ? $message = "Admin role revoked from {$target}."
                          : $error   = 'Error: ' . h($result['output']);
        }
    }

    if ($action === 'set_superadmin' && $role === 'superadmin') {
        $target = trim($_POST['admin_email'] ?? '');
        if (!validate_email($target)) {
            $error = 'Invalid email address.';
        } else {
            $result = run_maildb(['set-superadmin', $target]);
            $result['ok'] ? $message = "{$target} is now superadmin."
                          : $error   = 'Error: ' . h($result['output']);
        }
    }
}

$view_email    = (session_valid() && $_SESSION['role'] !== 'user')
    ? (trim($_GET['view'] ?? '') ?: $_SESSION['email'])
    : (session_valid() ? $_SESSION['email'] : '');
$view_vacation = $view_email ? get_vacation_status($view_email) : null;
?>
