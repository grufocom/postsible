# ============================================
# Main Command Dispatcher
# ============================================
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    list-domains)
        list_domains
        ;;
    list-domains-details)
        list_domains_details
        ;;
    add-domain)
        add_domain "$1"
        ;;
    remove-domain)
        force=false
        domain=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                --force) force=true; shift ;;
                *) domain="$1"; shift ;;
            esac
        done
        remove_domain "$domain" "$force"
        ;;
    list-users)
        list_users "$1"
        ;;
    add-user)
        add_user "$@"
        ;;
    remove-user)
        force=false
        email=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                --force) force=true; shift ;;
                *) email="$1"; shift ;;
            esac
        done
        remove_user "$email" "$force"
        ;;
    change-password)
        change_password "$@"
        ;;
    enable-user)
        enable_user "$1"
        ;;
    disable-user)
        disable_user "$1"
        ;;
    create-maildir)
        create_maildir "$1"
        ;;
    resend-welcome)
        resend_welcome "$1"
        ;;
    list-aliases)
        list_aliases "$1"
        ;;
    add-alias)
        add_alias "$1" "$2"
        ;;
    remove-alias)
        force=false
        source=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                --force) force=true; shift ;;
                *) source="$1"; shift ;;
            esac
        done
        remove_alias "$source" "$force"
        ;;
    set-vacation)
        set_vacation "$@"
        ;;
    get-vacation)
        get_vacation "$1"
        ;;
    disable-vacation)
        disable_vacation "$1"
        ;;
    add-vacation-admin)
        add_vacation_admin "$@"
        ;;
    remove-vacation-admin)
        remove_vacation_admin "$1"
        ;;
    list-vacation-admins)
        list_vacation_admins
        ;;
    set-superadmin)
        set_superadmin "$1"
        ;;
    stats)
        show_stats
        ;;
    check)
        check_database
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        show_help
        exit 1
        ;;
esac
