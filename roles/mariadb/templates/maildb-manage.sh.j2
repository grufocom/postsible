# ============================================
# Maildir Creation
# ============================================
create_maildir_internal() {
    local email=$1
    local silent=${2:-false}

    local domain="${email#*@}"
    local username="${email%%@*}"

    if [[ "$silent" == "false" ]]; then
        echo -e "${YELLOW}Creating Maildir structure for $email...${NC}"
    fi

    local maildir_path="/srv/imap/$domain/$username"

    mkdir -p "$maildir_path"/{Maildir/{cur,new,tmp},Maildir/.Drafts/{cur,new,tmp},Maildir/.Sent/{cur,new,tmp},Maildir/.Trash/{cur,new,tmp},Maildir/.Spam/{cur,new,tmp},Maildir/.Ham/{cur,new,tmp}}

    chown -R vmail:vmail "$maildir_path"
    chmod -R 0700 "$maildir_path"

    cat > "$maildir_path/Maildir/subscriptions" << EOF
INBOX
Drafts
Sent
Trash
Spam
Ham
EOF

    chown vmail:vmail "$maildir_path/Maildir/subscriptions"

    if [[ "$silent" == "false" ]]; then
        echo -e "${GREEN}Maildir structure created: $maildir_path${NC}"
    fi
}

create_maildir() {
    local email=$1
    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local user_exists=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE email='$email';")
    if [[ "$user_exists" -eq 0 ]]; then
        echo -e "${RED}Error: User $email does not exist in database${NC}"
        exit 1
    fi

    create_maildir_internal "$email" false
}

# ============================================
# Baikal Integration
# ============================================
# Neue Hilfsfunktion: F├╝hrt mehrere SQL-Statements in einer Verbindung aus
mysql_multi() {
    local sql="$1"
    mysql -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" -sN -e "$sql" 2>/dev/null
}

create_baikal_user() {
    local email=$1
    local password=$2
    local displayname=$3
    local domain=$(get_domain_from_email "$email")

    echo -e "${YELLOW}Creating Baikal user for $email (domain: $domain)...${NC}"

    local exists=$(baikal_cmd "SELECT COUNT(*) FROM users WHERE username='$email';")
    if [[ "$exists" -gt 0 ]]; then
        echo -e "${YELLOW}Baikal user already exists, skipping...${NC}"
        return 0
    fi

    local realm="BaikalDAV"
    local digest=$(echo -n "$email:$realm:$password" | md5sum | cut -d' ' -f1)

    if ! baikal_cmd "INSERT INTO users (username, digesta1) VALUES ('$email', '$digest');"; then
        echo -e "${RED}Error: Could not create Baikal user${NC}"
        return 1
    fi

    echo -e "${GREEN}Ō£ō Baikal user created${NC}"

    baikal_cmd "INSERT IGNORE INTO principals (uri, email, displayname) VALUES ('principals/$email', '$email', '$displayname');" 2>/dev/null

    local addressbook_uri="${email%%@*}-contacts"
    if baikal_cmd "INSERT INTO addressbooks (principaluri, displayname, uri, description, synctoken) VALUES ('principals/$email', 'Contacts', '$addressbook_uri', 'Default addressbook', 1);" 2>/dev/null; then
        echo -e "${GREEN}Ō£ō Addressbook created${NC}"
    else
        echo -e "${YELLOW}Warning: Could not create addressbook${NC}"
    fi

    local principal="principals/$email"
    
    # Check if calendar instance already exists for this user
    local calendar_id=$(baikal_cmd "SELECT calendarid FROM calendarinstances WHERE principaluri='$principal' AND uri='default' LIMIT 1;")

    if [[ -z "$calendar_id" ]]; then
        # Create calendar and instance in ONE transaction (same connection)
        local sql="
            START TRANSACTION;
            INSERT INTO calendars (synctoken, components) VALUES (1, 'VEVENT,VTODO');
            INSERT INTO calendarinstances (calendarid, principaluri, access, displayname, uri, description, calendarorder, calendarcolor, timezone, transparent, share_invitestatus) 
            VALUES (LAST_INSERT_ID(), '$principal', 1, 'Personal', 'default', 'Default calendar', 0, '#3a87adff', 'Europe/Vienna', 0, 2);
            COMMIT;
            SELECT LAST_INSERT_ID();
        "
        
        local new_calendar_id=$(mysql_multi "$sql")
        
        if [[ -n "$new_calendar_id" && "$new_calendar_id" -gt 0 ]]; then
            echo -e "${GREEN}Ō£ō Calendar created with ID $new_calendar_id${NC}"
        else
            echo -e "${RED}Error: Could not create calendar instance${NC}"
            return 1
        fi
    else
        echo -e "${GREEN}Ō£ō Calendar already exists for this user (ID $calendar_id) - reusing${NC}"
    fi

    echo -e "${GREEN}Ō£ō Baikal setup complete for $email${NC}"
}

remove_baikal_user() {
    local email=$1

    echo -e "${YELLOW}Removing Baikal user for $email...${NC}"

    local exists=$(baikal_cmd "SELECT COUNT(*) FROM users WHERE username='$email';")
    if [[ "$exists" -eq 0 ]]; then
        echo -e "${YELLOW}Baikal user does not exist, skipping...${NC}"
        return 0
    fi

    local principal="principals/$email"

    baikal_cmd "DELETE FROM cards WHERE addressbookid IN (SELECT id FROM addressbooks WHERE principaluri='$principal');" 2>/dev/null
    baikal_cmd "DELETE FROM addressbooks WHERE principaluri='$principal';" 2>/dev/null

    local calendar_ids=$(baikal_cmd "SELECT calendarid FROM calendarinstances WHERE principaluri='$principal';" | tr '\n' ',' | sed 's/,$//')

    if [[ -n "$calendar_ids" ]]; then
        baikal_cmd "DELETE FROM calendarinstances WHERE principaluri='$principal';" 2>/dev/null
        baikal_cmd "DELETE FROM calendarobjects WHERE calendarid IN ($calendar_ids);" 2>/dev/null
        baikal_cmd "DELETE FROM calendarchanges WHERE calendarid IN ($calendar_ids);" 2>/dev/null
        baikal_cmd "DELETE FROM calendars WHERE id IN ($calendar_ids);" 2>/dev/null
    fi

    baikal_cmd "DELETE FROM principals WHERE uri='$principal';" 2>/dev/null
    baikal_cmd "DELETE FROM users WHERE username='$email';" 2>/dev/null

    echo -e "${GREEN}Ō£ō Baikal user and data removed${NC}"
}

change_baikal_password() {
    local email=$1
    local password=$2

    echo -e "${YELLOW}Updating Baikal password for $email...${NC}"

    local exists=$(baikal_cmd "SELECT COUNT(*) FROM users WHERE username='$email';")
    if [[ "$exists" -eq 0 ]]; then
        echo -e "${YELLOW}Baikal user does not exist, skipping password update...${NC}"
        return 0
    fi

    local realm="BaikalDAV"
    local digest=$(echo -n "$email:$realm:$password" | md5sum | cut -d' ' -f1)

    baikal_cmd "UPDATE users SET digesta1='$digest' WHERE username='$email';" 2>/dev/null || {
        echo -e "${RED}Error: Could not update Baikal password${NC}"
        return 1
    }

    echo -e "${GREEN}Ō£ō Baikal password updated${NC}"
}

# ============================================
# Vacation / Out-of-office Functions
# ============================================
get_sieve_path() {
    local email=$1
    local domain="${email#*@}"
    local username="${email%%@*}"
    echo "/srv/imap/$domain/$username/.dovecot.sieve"
}

write_vacation_sieve() {
    local email=$1
    local date_from=$2
    local date_to=$3
    local subject=$4
    local message=$5
    local sieve_path=$(get_sieve_path "$email")

    local safe_subject="${subject//\"/\'}"
    local safe_message="${message//\"/\'}"

    cat > "$sieve_path" << EOF
require ["vacation", "date", "relational", "envelope"];

# Vacation / Out-of-office reply
# Generated by maildb-manage on $(date -R)
# Active from: $date_from to: $date_to

if anyof (
  exists "List-Id",
  exists "List-Unsubscribe",
  exists "List-Post",
  exists "X-Mailing-List",
  header :contains "Precedence" ["bulk", "list", "junk"],
  header :contains "Auto-Submitted" "auto"
) {
  stop;
}

if envelope :localpart :contains "from" [
  "noreply", "no-reply", "donotreply", "do-not-reply",
  "mailer-daemon", "postmaster", "bounce", "bounces",
  "notification", "notifications", "newsletter", "marketing",
  "automated", "robot", "daemon", "system"
] {
  stop;
}

if allof (
  currentdate :value "ge" "date" "$date_from",
  currentdate :value "le" "date" "$date_to"
) {
  vacation
    :days 7
    :subject "$safe_subject"
    :from "$email"
    "$safe_message";
}
EOF

    chown vmail:vmail "$sieve_path"
    chmod 600 "$sieve_path"

    if doveadm sieve recompile -u "$email" .dovecot 2>/dev/null; then
        echo -e "${GREEN}Ō£ō Sieve script compiled${NC}"
    else
        touch "$sieve_path"
        echo -e "${YELLOW}Note: Sieve recompile skipped, will activate on next mail delivery${NC}"
    fi
}

remove_vacation_sieve() {
    local email=$1
    local sieve_path=$(get_sieve_path "$email")

    if [[ -f "$sieve_path" ]]; then
        rm -f "$sieve_path"
        rm -f "${sieve_path}.svbin"
        echo -e "${GREEN}Ō£ō Sieve script removed${NC}"
    else
        echo -e "${YELLOW}No sieve script found for $email${NC}"
    fi
}

set_vacation() {
    local email=$1
    shift

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local date_from=""
    local date_to=""
    local subject=""
    local message=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --from) date_from="$2"; shift 2 ;;
            --to) date_to="$2"; shift 2 ;;
            --subject) subject="$2"; shift 2 ;;
            --message) message="$2"; shift 2 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    if [[ -z "$date_from" ]] || [[ -z "$date_to" ]] || [[ -z "$subject" ]] || [[ -z "$message" ]]; then
        echo -e "${RED}Error: --from, --to, --subject and --message are required${NC}"
        exit 1
    fi

    if ! echo "$date_from" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
        echo -e "${RED}Error: --from date must be in YYYY-MM-DD format${NC}"
        exit 1
    fi
    if ! echo "$date_to" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
        echo -e "${RED}Error: --to date must be in YYYY-MM-DD format${NC}"
        exit 1
    fi

    local user_exists=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE email='$email';")
    if [[ "$user_exists" -eq 0 ]]; then
        echo -e "${RED}Error: User $email does not exist${NC}"
        exit 1
    fi

    echo -e "${YELLOW}Setting vacation reply for $email...${NC}"
    echo -e "${YELLOW}  Period:  $date_from to $date_to${NC}"
    echo -e "${YELLOW}  Subject: $subject${NC}"

    write_vacation_sieve "$email" "$date_from" "$date_to" "$subject" "$message"

    local sql_subject="${subject//\'/\'\'}"
    local sql_message="${message//\'/\'\'}"

    mysql_cmd "INSERT INTO vacation_status (email, active, date_from, date_to, subject, message)
               VALUES ('$email', 1, '$date_from', '$date_to', '$sql_subject', '$sql_message')
               ON DUPLICATE KEY UPDATE
                 active=1, date_from='$date_from', date_to='$date_to',
                 subject='$sql_subject', message='$sql_message',
                 updated_at=NOW();"

    echo -e "${GREEN}Ō£ō Vacation reply active for $email ($date_from to $date_to)${NC}"
}

get_vacation() {
    local email=$1

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    echo -e "${BLUE}=== Vacation Status: $email ===${NC}"

    local result=$(mysql_cmd "SELECT active, date_from, date_to, subject, message, updated_at
                              FROM vacation_status WHERE email='$email';")

    if [[ -z "$result" ]]; then
        echo "No vacation reply configured."
        return 0
    fi

    local active date_from date_to subject message updated_at
    IFS=$'\t' read -r active date_from date_to subject message updated_at <<< "$result"

    local status_str
    if [[ "$active" == "1" ]]; then
        status_str="${GREEN}active${NC}"
    else
        status_str="${YELLOW}inactive${NC}"
    fi

    echo -e "Status:   $(echo -e $status_str)"
    echo    "From:     $date_from"
    echo    "To:       $date_to"
    echo    "Subject:  $subject"
    echo    "Message:  $message"
    echo    "Updated:  $updated_at"

    local sieve_path=$(get_sieve_path "$email")
    if [[ -f "$sieve_path" ]]; then
        echo -e "Sieve:    ${GREEN}script present on disk${NC}"
    else
        echo -e "Sieve:    ${YELLOW}script NOT found on disk${NC}"
    fi
}

disable_vacation() {
    local email=$1

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    echo -e "${YELLOW}Disabling vacation reply for $email...${NC}"

    remove_vacation_sieve "$email"

    mysql_cmd "UPDATE vacation_status SET active=0, updated_at=NOW() WHERE email='$email';" 2>/dev/null || true

    echo -e "${GREEN}Ō£ō Vacation reply disabled for $email${NC}"
}

# ============================================
# Vacation Admin Management
# ============================================
add_vacation_admin() {
    local email=$1
    shift

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local granted_by=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --granted-by) granted_by="$2"; shift 2 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    local user_exists=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE email='$email';")
    if [[ "$user_exists" -eq 0 ]]; then
        echo -e "${RED}Error: User $email does not exist${NC}"
        exit 1
    fi

    mysql_cmd "INSERT INTO vacation_admins (email, role, granted_by)
               VALUES ('$email', 'admin', '$granted_by')
               ON DUPLICATE KEY UPDATE granted_by='$granted_by';" 2>/dev/null || {
        echo -e "${RED}Error: Could not add vacation admin${NC}"
        exit 1
    }

    echo -e "${GREEN}Ō£ō Vacation admin role granted to $email${NC}"
}

remove_vacation_admin() {
    local email=$1

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local role=$(mysql_cmd "SELECT role FROM vacation_admins WHERE email='$email';")
    if [[ "$role" == "superadmin" ]]; then
        echo -e "${RED}Error: Cannot remove superadmin via this command. Use set-superadmin to reassign.${NC}"
        exit 1
    fi

    mysql_cmd "DELETE FROM vacation_admins WHERE email='$email';"
    echo -e "${GREEN}Ō£ō Vacation admin role revoked from $email${NC}"
}

list_vacation_admins() {
    echo -e "${BLUE}=== Vacation Admins ===${NC}"
    mysql_cmd "SELECT email, role, granted_by, created_at FROM vacation_admins ORDER BY role DESC, email;" \
    | while IFS=$'\t' read -r email role granted_by created_at; do
        echo "[$role] $email (granted by: ${granted_by:-system}, since: $created_at)"
    done
}

set_superadmin() {
    local email=$1

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local user_exists=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE email='$email';")
    if [[ "$user_exists" -eq 0 ]]; then
        echo -e "${RED}Error: User $email does not exist${NC}"
        exit 1
    fi

    mysql_cmd "INSERT INTO vacation_admins (email, role, granted_by)
               VALUES ('$email', 'superadmin', 'system')
               ON DUPLICATE KEY UPDATE role='superadmin';"

    echo -e "${GREEN}Ō£ō $email is now vacation superadmin${NC}"
}

# ============================================
# Domain Management (Multi-Domain)
# ============================================
list_domains() {
    echo -e "${BLUE}=== Virtual Domains ===${NC}"
    mysql_cmd "SELECT id, name, created_at FROM virtual_domains ORDER BY name;" | while IFS=$'\t' read -r id name created; do
        local user_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE domain_id=$id;")
        local alias_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_aliases WHERE domain_id=$id;")
        echo "[$id] $name (users: $user_count, aliases: $alias_count, created: $created)"
    done
}

list_domains_details() {
    echo -e "${BLUE}=== Virtual Domains with Details ===${NC}"
    mysql_cmd "SELECT d.id, d.name, d.created_at,
               (SELECT COUNT(*) FROM virtual_users u WHERE u.domain_id=d.id) as user_count,
               (SELECT COUNT(*) FROM virtual_aliases a WHERE a.domain_id=d.id) as alias_count
               FROM virtual_domains d 
               ORDER BY d.name;" | while IFS=$'\t' read -r id name created users aliases; do
        echo "[$id] $name (created: $created) - users: $users, aliases: $aliases"
    done
}

add_domain() {
    local domain=$1
    if [[ -z "$domain" ]]; then
        echo -e "${RED}Error: Domain name required${NC}"
        exit 1
    fi

    echo -e "${YELLOW}Adding domain: $domain${NC}"
    mysql_cmd "INSERT INTO virtual_domains (name) VALUES ('$domain');" 2>/dev/null || {
        echo -e "${RED}Error: Domain already exists or invalid${NC}"
        exit 1
    }

    echo -e "${GREEN}Domain added successfully!${NC}"
}

remove_domain() {
    local domain=$1
    local force=${2:-false}

    if [[ -z "$domain" ]]; then
        echo -e "${RED}Error: Domain name required${NC}"
        exit 1
    fi

    if [[ "$force" != "true" ]]; then
        local user_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users u JOIN virtual_domains d ON u.domain_id=d.id WHERE d.name='$domain';")
        local alias_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_aliases a JOIN virtual_domains d ON a.domain_id=d.id WHERE d.name='$domain';")
        echo -e "${RED}WARNING: This will delete:${NC}"
        echo -e "${RED}  ŌĆó Domain: $domain${NC}"
        echo -e "${RED}  ŌĆó Users: $user_count${NC}"
        echo -e "${RED}  ŌĆó Aliases: $alias_count${NC}"
        echo -e "${YELLOW}Are you sure? (yes/no):${NC}"
        read -r confirm
        if [[ "$confirm" != "yes" ]]; then
            echo "Cancelled."
            exit 0
        fi
    fi

    # Get domain_id for cleanup
    local domain_id=$(mysql_cmd "SELECT id FROM virtual_domains WHERE name='$domain';")
    
    if [[ -n "$domain_id" ]]; then
        # Get all users for this domain
        local users=$(mysql_cmd "SELECT email FROM virtual_users WHERE domain_id='$domain_id';")
        for email in $users; do
            echo -e "${YELLOW}Removing user: $email${NC}"
            remove_baikal_user "$email" 2>/dev/null
            disable_vacation "$email" 2>/dev/null
            mysql_cmd "DELETE FROM vacation_status WHERE email='$email';" 2>/dev/null
            mysql_cmd "DELETE FROM vacation_admins WHERE email='$email';" 2>/dev/null
        done
    fi

    mysql_cmd "DELETE FROM virtual_domains WHERE name='$domain';"
    echo -e "${GREEN}Domain removed!${NC}"
}

# ============================================
# User Management (Multi-Domain)
# ============================================
list_users() {
    local domain=$1
    echo -e "${BLUE}=== Virtual Users ===${NC}"

    if [[ -z "$domain" ]]; then
        mysql_cmd "SELECT u.id, u.email, d.name, u.quota, u.enabled, u.created_at 
                    FROM virtual_users u 
                    JOIN virtual_domains d ON u.domain_id=d.id 
                    ORDER BY d.name, u.email;" | while IFS=$'\t' read -r id email domain_name quota enabled created; do
            status=$([ "$enabled" = "1" ] && echo "enabled" || echo "disabled")
            local baikal_exists=$(baikal_cmd "SELECT COUNT(*) FROM users WHERE username='$email';")
            local baikal_status=""
            if [[ "$baikal_exists" -gt 0 ]]; then
                baikal_status=" [Baikal: Ō£ō]"
            else
                baikal_status=" [Baikal: Ō£Ś]"
            fi
            echo "[$id] $email (domain: $domain_name, quota: $quota, status: $status, created: $created)$baikal_status"
        done
    else
        mysql_cmd "SELECT u.id, u.email, u.quota, u.enabled, u.created_at 
                    FROM virtual_users u 
                    JOIN virtual_domains d ON u.domain_id=d.id 
                    WHERE d.name='$domain' 
                    ORDER BY u.email;" | while IFS=$'\t' read -r id email quota enabled created; do
            status=$([ "$enabled" = "1" ] && echo "enabled" || echo "disabled")
            local baikal_exists=$(baikal_cmd "SELECT COUNT(*) FROM users WHERE username='$email';")
            local baikal_status=""
            if [[ "$baikal_exists" -gt 0 ]]; then
                baikal_status=" [Baikal: Ō£ō]"
            else
                baikal_status=" [Baikal: Ō£Ś]"
            fi
            echo "[$id] $email (quota: $quota, status: $status, created: $created)$baikal_status"
        done
    fi
}

add_user() {
    local email=$1
    shift

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local password=""
    local displayname=""
    local auto_password=false
    local quiet=false
    local send_welcome=true

    while [[ $# -gt 0 ]]; do
        case $1 in
            --password) password="$2"; shift 2 ;;
            --displayname) displayname="$2"; shift 2 ;;
            --auto-password) auto_password=true; shift ;;
            --quiet) quiet=true; shift ;;
            --no-welcome) send_welcome=false; shift ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    local domain="${email#*@}"
    local username="${email%%@*}"

    local domain_id=$(mysql_cmd "SELECT id FROM virtual_domains WHERE name='$domain';")
    if [[ -z "$domain_id" ]]; then
        echo -e "${RED}Error: Domain $domain does not exist. Add it first with: add-domain $domain${NC}"
        echo -e "${YELLOW}Available domains:${NC}"
        mysql_cmd "SELECT name FROM virtual_domains ORDER BY name;" | while read d; do
            echo "  - $d"
        done
        exit 1
    fi

    if [[ -z "$displayname" ]]; then
        if [[ "$auto_password" == "true" ]] || [[ -n "$password" ]]; then
            displayname="$username"
        else
            echo -e "${YELLOW}Enter display name for $email (optional, press Enter to skip):${NC}"
            read displayname
            if [[ -z "$displayname" ]]; then
                displayname="$username"
            fi
        fi
    fi

    if [[ "$auto_password" == "true" ]]; then
        password=$(generate_password)
        if [[ "$quiet" != "true" ]]; then
            echo -e "${GREEN}Generated password: $password${NC}"
            echo -e "${YELLOW}Please save this password securely!${NC}"
        else
            echo "$password"
        fi
    elif [[ -z "$password" ]]; then
        echo -e "${YELLOW}Enter password for $email:${NC}"
        read -s password
        echo ""
        echo -e "${YELLOW}Confirm password:${NC}"
        read -s password_confirm
        echo ""

        if [[ "$password" != "$password_confirm" ]]; then
            echo -e "${RED}Error: Passwords do not match${NC}"
            exit 1
        fi
    fi

    if command -v doveadm &> /dev/null; then
        hashed_password=$(doveadm pw -s SHA512-CRYPT -p "$password")
    else
        hashed_password=$(mkpasswd -m sha-512 "$password")
    fi

    mysql_cmd "INSERT INTO virtual_users (domain_id, email, password) VALUES ('$domain_id', '$email', '$hashed_password');" 2>/dev/null || {
        echo -e "${RED}Error: User already exists or invalid${NC}"
        exit 1
    }

    if [[ "$quiet" != "true" ]]; then
        echo -e "${GREEN}User $email created successfully in database!${NC}"
    fi

    if [[ "$quiet" != "true" ]]; then
        echo ""
    fi
    create_maildir_internal "$email" "$quiet"

    if [[ "$quiet" != "true" ]]; then
        echo ""
    fi
    create_baikal_user "$email" "$password" "$displayname"

    if [[ "$send_welcome" == "true" ]]; then
        if [[ "$quiet" != "true" ]]; then
            echo ""
        fi
        send_welcome_email "$email" "$password" "$displayname"
    fi

    if [[ "$quiet" != "true" ]]; then
        echo ""
        echo -e "${GREEN}Ō£ō Complete setup finished!${NC}"
        echo -e "${BLUE}User can now:${NC}"
        echo -e "${BLUE}  ŌĆó Receive and send emails${NC}"
        echo -e "${BLUE}  ŌĆó Access contacts via CardDAV${NC}"
        echo -e "${BLUE}  ŌĆó Access calendar via CalDAV${NC}"
        local webmail_domain=$(get_webmail_domain "$email")
        echo -e "${BLUE}  ŌĆó Access webmail at https://$webmail_domain/wm/${NC}"
        echo -e "${BLUE}  ŌĆó Use InfCloud at https://$HOSTNAME/cal/${NC}"
        if [[ "$send_welcome" == "true" ]]; then
            echo -e "${GREEN}  ŌĆó Welcome email sent with all details!${NC}"
        fi
    fi
}

remove_user() {
    local email=$1
    local force=${2:-false}

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    if [[ "$force" != "true" ]]; then
        echo -e "${RED}WARNING: This will delete:${NC}"
        echo -e "${RED}  ŌĆó The mail user and all emails${NC}"
        echo -e "${RED}  ŌĆó The Baikal account (contacts & calendars)${NC}"
        echo -e "${YELLOW}Are you sure? (yes/no):${NC}"
        read -r confirm
        if [[ "$confirm" != "yes" ]]; then
            echo "Cancelled."
            exit 0
        fi
    fi

    mysql_cmd "DELETE FROM virtual_users WHERE email='$email';"
    echo -e "${GREEN}User removed from mail database!${NC}"

    remove_baikal_user "$email"

    disable_vacation "$email" 2>/dev/null || true

    mysql_cmd "DELETE FROM vacation_status WHERE email='$email';" 2>/dev/null || true
    mysql_cmd "DELETE FROM vacation_admins WHERE email='$email';" 2>/dev/null || true

    local domain="${email#*@}"
    local username="${email%%@*}"
    local maildir_path="/srv/imap/$domain/$username"

    if [[ -d "$maildir_path" ]]; then
        echo -e "${YELLOW}Maildir still exists at: $maildir_path${NC}"
        echo -e "${YELLOW}Remove manually if needed: rm -rf $maildir_path${NC}"
    fi

    echo -e "${GREEN}Ō£ō User completely removed!${NC}"
}

change_password() {
    local email=$1
    shift

    if [[ -z "$email" ]]; then
        echo -e "${RED}Error: Email address required${NC}"
        exit 1
    fi

    local password=""
    local auto_password=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --password) password="$2"; shift 2 ;;
            --auto-password) auto_password=true; shift ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    if [[ "$auto_password" == "true" ]]; then
        password=$(generate_password)
        echo -e "${GREEN}Generated password: $password${NC}"
        echo -e "${YELLOW}Please save this password securely!${NC}"
    elif [[ -z "$password" ]]; then
        echo -e "${YELLOW}Enter new password for $email:${NC}"
        read -s password
        echo ""
        echo -e "${YELLOW}Confirm password:${NC}"
        read -s password_confirm
        echo ""

        if [[ "$password" != "$password_confirm" ]]; then
            echo -e "${RED}Error: Passwords do not match${NC}"
            exit 1
        fi
    fi

    if command -v doveadm &> /dev/null; then
        hashed_password=$(doveadm pw -s SHA512-CRYPT -p "$password")
    else
        hashed_password=$(mkpasswd -m sha-512 "$password")
    fi

    mysql_cmd "UPDATE virtual_users SET password='$hashed_password' WHERE email='$email';"
    echo -e "${GREEN}Mail password changed successfully!${NC}"

    change_baikal_password "$email" "$password"

    echo -e "${GREEN}Ō£ō Password changed for both Mail and Baikal!${NC}"
}

enable_user() {
    mysql_cmd "UPDATE virtual_users SET enabled=1 WHERE email='$1';"
    echo -e "${GREEN}User enabled${NC}"
}

disable_user() {
    mysql_cmd "UPDATE virtual_users SET enabled=0 WHERE email='$1';"
    echo -e "${YELLOW}User disabled${NC}"
}

# ============================================
# Alias Management (Multi-Domain)
# ============================================
list_aliases() {
    local domain=$1
    echo -e "${BLUE}=== Virtual Aliases ===${NC}"

    if [[ -z "$domain" ]]; then
        mysql_cmd "SELECT a.id, a.source, a.destination, d.name FROM virtual_aliases a JOIN virtual_domains d ON a.domain_id=d.id ORDER BY d.name, a.source;" | while IFS=$'\t' read -r id source dest domain_name; do
            echo "[$id] $source ŌåÆ $dest (domain: $domain_name)"
        done
    else
        mysql_cmd "SELECT a.id, a.source, a.destination FROM virtual_aliases a JOIN virtual_domains d ON a.domain_id=d.id WHERE d.name='$domain' ORDER BY a.source;" | while IFS=$'\t' read -r id source dest; do
            echo "[$id] $source ŌåÆ $dest"
        done
    fi
}

add_alias() {
    local source=$1
    local destination=$2

    if [[ -z "$source" ]] || [[ -z "$destination" ]]; then
        echo -e "${RED}Error: Source and destination required${NC}"
        echo "Usage: add-alias source@domain.com destination@domain.com"
        exit 1
    fi

    local domain="${source#*@}"
    local domain_id=$(mysql_cmd "SELECT id FROM virtual_domains WHERE name='$domain';")
    if [[ -z "$domain_id" ]]; then
        echo -e "${RED}Error: Domain $domain does not exist${NC}"
        exit 1
    fi

    mysql_cmd "INSERT INTO virtual_aliases (domain_id, source, destination) VALUES ('$domain_id', '$source', '$destination');" 2>/dev/null || {
        echo -e "${RED}Error: Alias already exists or invalid${NC}"
        exit 1
    }

    echo -e "${GREEN}Alias created: $source ŌåÆ $destination${NC}"
}

remove_alias() {
    local source=$1
    local force=${2:-false}

    if [[ -z "$source" ]]; then
        echo -e "${RED}Error: Source address required${NC}"
        exit 1
    fi

    if [[ "$force" != "true" ]]; then
        echo -e "${YELLOW}Remove alias $source? (yes/no):${NC}"
        read -r confirm
        if [[ "$confirm" != "yes" ]]; then
            echo "Cancelled."
            exit 0
        fi
    fi

    mysql_cmd "DELETE FROM virtual_aliases WHERE source='$source';"
    echo -e "${GREEN}Alias removed!${NC}"
}

# ============================================
# Statistics and Checks (Multi-Domain)
# ============================================
show_stats() {
    echo -e "${BLUE}=== Database Statistics ===${NC}"

    local domain_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_domains;")
    local user_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users;")
    local alias_count=$(mysql_cmd "SELECT COUNT(*) FROM virtual_aliases;")
    local enabled_users=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE enabled=1;")
    local baikal_users=$(baikal_cmd "SELECT COUNT(*) FROM users;")
    local vacation_active=$(mysql_cmd "SELECT COUNT(*) FROM vacation_status WHERE active=1;")

    echo "Total Domains: $domain_count"
    echo "Total Users: $user_count (enabled: $enabled_users)"
    echo "Total Aliases: $alias_count"
    echo "Baikal users: $baikal_users"
    echo "Active vacation replies: $vacation_active"

    echo ""
    echo -e "${BLUE}=== Users per Domain ===${NC}"
    mysql_cmd "SELECT d.name, COUNT(u.id) FROM virtual_domains d LEFT JOIN virtual_users u ON d.id=u.domain_id GROUP BY d.name ORDER BY d.name;" | while IFS=$'\t' read -r domain count; do
        echo "  $domain: $count users"
    done

    echo ""
    echo -e "${BLUE}=== Aliases per Domain ===${NC}"
    mysql_cmd "SELECT d.name, COUNT(a.id) FROM virtual_domains d LEFT JOIN virtual_aliases a ON d.id=a.domain_id GROUP BY d.name ORDER BY d.name;" | while IFS=$'\t' read -r domain count; do
        echo "  $domain: $count aliases"
    done
}

check_database() {
    echo -e "${BLUE}=== Database Integrity Check ===${NC}"

    local orphaned=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users WHERE domain_id NOT IN (SELECT id FROM virtual_domains);")
    if [[ "$orphaned" -gt 0 ]]; then
        echo -e "${RED}WARNING: $orphaned orphaned user records found!${NC}"
    else
        echo -e "${GREEN}No orphaned user records${NC}"
    fi

    local duplicate_orphaned=$(mysql_cmd "SELECT COUNT(*) FROM virtual_aliases WHERE domain_id NOT IN (SELECT id FROM virtual_domains);")
    if [[ "$duplicate_orphaned" -gt 0 ]]; then
        echo -e "${RED}WARNING: $duplicate_orphaned orphaned alias records found!${NC}"
    else
        echo -e "${GREEN}No orphaned alias records${NC}"
    fi

    local duplicates=$(mysql_cmd "SELECT COUNT(*) FROM (SELECT email FROM virtual_users GROUP BY email HAVING COUNT(*) > 1) AS dups;")
    if [[ "$duplicates" -gt 0 ]]; then
        echo -e "${RED}WARNING: $duplicates duplicate email addresses found!${NC}"
    else
        echo -e "${GREEN}No duplicate emails${NC}"
    fi

    echo ""
    echo -e "${BLUE}=== Baikal Sync Check ===${NC}"
    local mail_users=$(mysql_cmd "SELECT COUNT(*) FROM virtual_users;")
    local baikal_users=$(baikal_cmd "SELECT COUNT(*) FROM users;")

    if [[ "$mail_users" -ne "$baikal_users" ]]; then
        echo -e "${YELLOW}WARNING: Mail users ($mail_users) != Baikal users ($baikal_users)${NC}"
        echo -e "${YELLOW}Some users may be missing in Baikal${NC}"
    else
        echo -e "${GREEN}Mail and Baikal user count matches${NC}"
    fi

    echo ""
    echo -e "${BLUE}=== Vacation Sieve Check ===${NC}"
    local vacation_issues=0
    while read -r vemail; do
        local sieve_path=$(get_sieve_path "$vemail")
        if [[ ! -f "$sieve_path" ]]; then
            echo -e "${YELLOW}WARNING: Vacation active in DB but sieve script missing for $vemail${NC}"
            vacation_issues=$((vacation_issues + 1))
        fi
    done < <(mysql_cmd "SELECT email FROM vacation_status WHERE active=1;")
    if [[ "$vacation_issues" -eq 0 ]]; then
        echo -e "${GREEN}All active vacation sieve scripts present on disk${NC}"
    fi

    echo -e "${GREEN}Database check completed${NC}"
}

