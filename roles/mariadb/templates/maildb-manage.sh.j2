#!/bin/bash
# {{ ansible_managed }}
# Database management script for Postsible with Baikal integration
# Multi-domain ready version

set -e

# ============================================
# Database Configuration
# ============================================
DB_NAME="{{ mariadb_database }}"
DB_USER="root"
DB_PASS="{{ mariadb_root_password }}"
HOSTNAME="{{ common_hostname }}"

# ============================================
# Helper Functions
# ============================================

# Extract domain from email address
get_domain_from_email() {
    local email=$1
    echo "${email#*@}"
}

# Get webmail domain for a specific email
get_webmail_domain() {
    local email=$1
    local domain=$(get_domain_from_email "$email")
    
    # Try to find webmail_domain from mail_virtual_domains if defined
    # Fallback to mail.domain
    {% if mail_virtual_domains is defined and mail_virtual_domains|length > 0 %}
    # Build domain mapping from Ansible variables
    # This is a static mapping that will be inserted at template time
    case "$domain" in
        {% for domain_item in mail_virtual_domains %}
        "{{ domain_item.domain }}")
            echo "{{ domain_item.mx_hostname }}"
            return
            ;;
        {% endfor %}
        *)
            echo "mail.$domain"
            ;;
    esac
    {% else %}
    echo "mail.$domain"
    {% endif %}
}

# Get DAV base URL for a specific email
get_dav_base_url() {
    local email=$1
    local domain=$(get_domain_from_email "$email")
    echo "https://$(get_webmail_domain "$email")/dav/dav.php"
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# MySQL command wrapper
mysql_cmd() {
    mysql -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" -sN -e "$1" 2>/dev/null
}

# Baikal MySQL command wrapper
baikal_cmd() {
    mysql -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" -sN -e "$1" 2>/dev/null
}

# Generate secure random password
generate_password() {
    openssl rand -base64 32 | tr -d '/+=' | cut -c1-20
}

